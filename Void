local function angleDiff(f, t)
    local d = t - f
    return ((d + math.pi) % (math.pi * 2)) - math.pi
end

local function isSameTeam(p)
    local same = false
    pcall(function()
        local mi = LP:GetAttribute("TeamID")
        local ti = p:GetAttribute("TeamID")
        if mi ~= nil and ti ~= nil then same = (mi == ti) end
    end)
    if not same then
        pcall(function()
            same = p.Team ~= nil and LP.Team ~= nil and p.Team == LP.Team
        end)
    end
    return same
end

local function isVisible(origin, targetPart)
    if not targetPart then return false end
    local ok, result = pcall(function()
        cachedVisRayParams.FilterDescendantsInstances = {
            LP.Character, targetPart.Parent, Workspace:FindFirstChild("Debris")
        }
        local dir = targetPart.Position - origin
        local hit = Workspace:Raycast(origin, dir, cachedVisRayParams)
        return hit == nil or hit.Instance:IsDescendantOf(targetPart.Parent)
    end)
    return ok and result or false
end

-- ═══════════════════════════════════════════
-- AIMBOT
-- ═══════════════════════════════════════════
local lockedTarget  = nil
local lockTimer     = 0
local reactionTimer = 0
local isInReaction  = false
local delayedPos    = nil

local fovCircle = Drawing.new("Circle")
fovCircle.NumSides     = 64
fovCircle.Visible      = false
fovCircle.Color        = Color3.fromRGB(255, 255, 255)
fovCircle.Thickness    = 1.5
fovCircle.Transparency = 0.7
fovCircle.Filled       = false

local function getEffectiveAimbotFOV()
    local f = AimbotCFG.MaxFOV
    if AimbotCFG.DynamicFOV then f = f * (camera.FieldOfView / 70) end
    return f
end

local function isInFOV(part)
    if not part then return false end
    local sp, on = camera:WorldToViewportPoint(part.Position)
    if not on then return false end
    return (Vector2.new(sp.X, sp.Y) - getScreenCenter()).Magnitude <= getEffectiveAimbotFOV()
end

local function resetDelayedPos() delayedPos = nil end

local function getDelayedPos(targetPart, dt)
    if not targetPart or not targetPart.Parent then delayedPos = nil; return nil end
    local real = targetPart.Position
    if not delayedPos then delayedPos = real; return real end
    local isJumping = false
    pcall(function()
        local hrp = targetPart.Parent:FindFirstChild("HumanoidRootPart")
        if hrp then isJumping = hrp.AssemblyLinearVelocity.Y > 2 end
    end)
    local frames = 60 * dt
    local xA = math.clamp((1 - AimbotCFG.XSmooth) * (1 + frames), 0.01, 1)
    local yA = (isJumping and AimbotCFG.JumpSmooth > 0)
        and math.clamp((1 - AimbotCFG.JumpSmooth) * (1 + frames), 0.01, 1)
        or  math.clamp((1 - AimbotCFG.YSmooth)    * (1 + frames), 0.01, 1)
    delayedPos = Vector3.new(
        delayedPos.X + (real.X - delayedPos.X) * xA,
        delayedPos.Y + (real.Y - delayedPos.Y) * yA,
        delayedPos.Z + (real.Z - delayedPos.Z) * xA
    )
    return delayedPos
end

local function isTargetValid(part)
    if not part or not part.Parent then return false end
    local hum = part.Parent:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if not isInFOV(part) then return false end
    if AimbotCFG.VisibleCheck and not isVisible(camera.CFrame.Position, part) then return false end
    if AimbotCFG.TeamCheck then
        local p = Players:GetPlayerFromCharacter(part.Parent)
        if p and isSameTeam(p) then return false end
    end
    return true
end

local function findAimbotTarget()
    local center = getScreenCenter()
    local fov    = getEffectiveAimbotFOV()
    local best, bd = nil, fov
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end
        if AimbotCFG.TeamCheck and isSameTeam(p) then continue end
        local ch = p.Character
        if not ch then continue end
        local hum = ch:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local part = getBestPart(ch, AimbotCFG.TargetPart)
        if not part then continue end
        local sp, on = camera:WorldToViewportPoint(part.Position)
        if not on then continue end
        local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if d > fov then continue end
        if AimbotCFG.VisibleCheck and not isVisible(camera.CFrame.Position, part) then continue end
        if d < bd then bd = d; best = part end
    end
    return best
end

