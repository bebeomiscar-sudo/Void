-- ═══════════════════════════════════════════
-- UTILITY FUNCTIONS
-- ═══════════════════════════════════════════
local function hasBall()
    local has = false
    pcall(function()
        -- Check character for ball
        for _, obj in ipairs(character:GetDescendants()) do
            if obj.Name:lower():find("ball") or obj.Name:lower():find("basketball") then
                has = true
                return
            end
        end
        -- Check if ball is welded to character
        for _, weld in ipairs(character:GetDescendants()) do
            if weld:IsA("Weld") or weld:IsA("Motor6D") then
                if weld.Part1 and weld.Part1.Name:lower():find("ball") then
                    has = true
                    return
                end
            end
        end
    end)
    return has
end

local function findNearestHoop()
    local nearest = nil
    local dist = math.huge
    
    pcall(function()
        for _, obj in ipairs(workspace:GetDescendants()) do
            local name = obj.Name:lower()
            if name:find("hoop") or name:find("rim") or name:find("basket") or name:find("goal") then
                if obj:IsA("BasePart") then
                    local d = (obj.Position - hrp.Position).Magnitude
                    if d < dist then
                        dist = d
                        nearest = obj
                    end
                end
            end
        end
    end)
    
    return nearest, dist
end

-- ═══════════════════════════════════════════
-- DUNK SYSTEM
-- ═══════════════════════════════════════════
local dunkConn = nil

local function doDunk()
    local args = {false}
    pcall(function()
        Remotes.Dunk:FireServer(unpack(args))
    end)
end

local function startAutoDunk()
    if dunkConn then dunkConn:Disconnect() end
    
    dunkConn = RunService.Heartbeat:Connect(function()
        if not CFG.AutoDunk then return end
        
        if hasBall() then
            local hoop, dist = findNearestHoop()
            if hoop and dist < 15 then -- Close to hoop
                doDunk()
                task.wait(0.5)
            end
        end
    end)
end

local function stopAutoDunk()
    if dunkConn then
        dunkConn:Disconnect()
        dunkConn = nil
    end
end

