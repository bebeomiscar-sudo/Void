-- ============================================================
-- // TRACER DRAW
-- ============================================================
local function DrawTracer(origin, endpoint, color)
    local c = cfg.useGameColor and color or cfg.tracerColor
    local dist = (endpoint - origin).Magnitude
    if dist < 0.5 then return end

    local beam = Instance.new("Part")
    beam.Anchored    = true
    beam.CanCollide  = false
    beam.CastShadow  = false
    beam.Material    = cfg.tracerMaterial
    beam.Color       = c
    beam.Size        = Vector3.new(cfg.tracerWidth, cfg.tracerWidth, dist)
    beam.CFrame      = CFrame.new(origin, endpoint) * CFrame.new(0, 0, -dist/2)
    beam.Parent      = workspace

    local t = 0
    local conn
    conn = run.Heartbeat:Connect(function(dt)
        t = t + dt
        beam.Transparency = t / cfg.tracerDuration
        if t >= cfg.tracerDuration then
            conn:Disconnect()
            beam:Destroy()
        end
    end)
end

-- Impact flash
local function DrawFlash(pos, color)
    local f = Instance.new("Part")
    f.Anchored   = true
    f.CanCollide = false
    f.CastShadow = false
    f.Material   = Enum.Material.Neon
    f.Color      = color or cfg.tracerColor
    f.Shape      = Enum.PartType.Ball
    f.Size       = Vector3.one * 0.5
    f.Position   = pos
    f.Parent     = workspace
    local t = 0
    local conn
    conn = run.Heartbeat:Connect(function(dt)
        t = t + dt
        local a = t / 0.15
        f.Transparency = a
        f.Size = Vector3.one * (0.5 + a * 0.5)
        if a >= 1 then conn:Disconnect(); f:Destroy() end
    end)
end

-- ============================================================
-- // FIX: HOOK LOCAL PLAYER'S OWN SHOTS
-- // CheckShot fires when YOU shoot — args[5]=origin CFrame, args[6]=endpoint
-- // We intercept FireServer to draw YOUR tracer in your custom color
-- ============================================================
local origCheckShotFire = CheckShot.FireServer
CheckShot.FireServer = function(self, ...)
    -- Draw local tracer BEFORE firing to server
    if cfg.tracerEnabled then
        local args = {...}
        -- args[5] = origin CFrame, args[6] = endpoint vector
        local originCF  = args[5]
        local endpointV = args[6]
        if originCF and endpointV then
            local ok1 = typeof(originCF)  == "CFrame"
            local ok2 = typeof(endpointV) == "Vector3"
                     or (type(endpointV) == "vector")
            if ok1 and ok2 then
                local origin = originCF.Position
                local endpoint = typeof(endpointV) == "Vector3"
                    and endpointV
                    or  Vector3.new(endpointV.X, endpointV.Y, endpointV.Z)
                DrawTracer(origin, endpoint, cfg.tracerColor)
            end
        end
    end
    return origCheckShotFire(self, ...)
end

-- Enemy/other player tracers (from server broadcast)
ProjectileRender.OnClientEvent:Connect(function(data)
    if not cfg.tracerEnabled then return end
    if type(data) ~= "table" then return end
    local o = data.Origin
    local e = data.Endpoint
    local c = data.LaserColor or cfg.tracerColor
    if o and e then
        DrawTracer(
            Vector3.new(o.X, o.Y, o.Z),
            Vector3.new(e.X, e.Y, e.Z),
            c
        )
    end
end)

ProjectileFinished.OnClientEvent:Connect(function(data)
    if not cfg.tracerEnabled then return end
    if type(data) ~= "table" then return end
    local hitCF = data.CFrame
    if hitCF then DrawFlash(hitCF.Position, data.ExpColor or data.LaserColor) end
end)

