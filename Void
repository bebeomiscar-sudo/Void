local function showHit(amount)
    if not hitEnabled then return end
    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.AutomaticSize          = Enum.AutomaticSize.XY
    lbl.Text                   = tostring(math.floor(amount + 0.5))
    lbl.Font                   = Enum.Font.Jura
    lbl.TextColor3             = hitColor
    lbl.TextSize               = 50
    lbl.TextStrokeTransparency = 0
    lbl.TextStrokeColor3       = Color3.new(0, 0, 0)
    lbl.TextTransparency       = 1
    lbl.Position               = UDim2.new(0.5, math.random(-150, 150), 0.45, math.random(-80, 80))
    lbl.AnchorPoint            = Vector2.new(0.5, 0.5)
    lbl.Parent                 = hitGui
    TweenService:Create(lbl, TweenInfo.new(0.2), {TextTransparency = 0}):Play()
    task.delay(hitDuration, function()
        TweenService:Create(lbl, TweenInfo.new(0.8), {TextTransparency = 1}):Play()
        task.wait(0.8); lbl:Destroy()
    end)
end

local function hookHumanoid(hum)
    local last = hum.Health
    hum.HealthChanged:Connect(function(hp)
        local dmg = last - hp
        if dmg > 0.1 then showHit(dmg) end
        last = hp
    end)
end

Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(function(ch)
        local h = ch:WaitForChild("Humanoid", 5)
        if h then hookHumanoid(h) end
    end)
end)
for _, p in ipairs(Players:GetPlayers()) do
    if p.Character then
        local h = p.Character:FindFirstChild("Humanoid")
        if h then hookHumanoid(h) end
    end
end

