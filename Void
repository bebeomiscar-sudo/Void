-- =============================================
-- TARGET PART PRESETS
-- =============================================
local PART_PRESETS = {
    ["Head"]       = {"Head"},
    ["HRP"]        = {"HumanoidRootPart"},
    ["Torso"]      = {"UpperTorso","LowerTorso","HumanoidRootPart"},
    ["Head, Body"] = {"Head","UpperTorso","LowerTorso","HumanoidRootPart"},
    ["Random"]     = {"Head","UpperTorso","LowerTorso","LeftUpperArm","RightUpperArm"},
}

local function getBestPart(model, setting)
    local preset = PART_PRESETS[setting] or {"Head"}
    if setting == "Random" then
        local pool = {}
        for _, n in ipairs(preset) do
            local p = model:FindFirstChild(n)
            if p then table.insert(pool, p) end
        end
        return #pool > 0 and pool[math.random(1, #pool)] or nil
    end
    for _, n in ipairs(preset) do
        local p = model:FindFirstChild(n)
        if p then return p end
    end
    return nil
end

-- =============================================
-- UTILITIES
-- =============================================
local function isSameTeam(p)
    local my    = LocalPlayer:GetAttribute("TeamID")
    local their = p:GetAttribute("TeamID")
    if my ~= nil and their ~= nil then return my == their end
    return LocalPlayer.Team ~= nil
        and p.Team ~= nil
        and LocalPlayer.Team == p.Team
end

local function isAlive(fighter)
    if not fighter then return false end
    local ok, alive = pcall(function()
        return fighter.State and fighter.State:IsAliveCached()
    end)
    return ok and alive
end

local visParams = RaycastParams.new()
visParams.FilterType = Enum.RaycastFilterType.Exclude

local function isVisible(origin, targetPart)
    pcall(function()
        visParams.FilterDescendantsInstances = {
            LocalPlayer.Character,
            targetPart.Parent,
        }
    end)
    local dir = targetPart.Position - origin
    local hit = Workspace:Raycast(origin, dir.Unit * dir.Magnitude * 0.95, visParams)
    return not hit or hit.Instance:IsDescendantOf(targetPart.Parent)
end

local function isWeaponBlacklisted(itemName)
    if not itemName then return false end
    for key, blacklisted in pairs(Config.WeaponBlacklist) do
        if blacklisted and itemName:lower():find(key:lower()) then
            return true
        end
    end
    return false
end

