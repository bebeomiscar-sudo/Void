-- ═══════════════════════════════════════════
-- INDICATORS
-- ═══════════════════════════════════════════
local ballGui, hoopGui = nil, nil
local indicatorConn = nil

local function startIndicators()
    if ballGui then ballGui:Destroy() end
    ballGui = Instance.new("ScreenGui")
    ballGui.Name = "BallInd"
    ballGui.ResetOnSpawn = false
    ballGui.Parent = LP:WaitForChild("PlayerGui")
    
    local ballFrame = Instance.new("Frame")
    ballFrame.Name = "Ball"
    ballFrame.BackgroundColor3 = CFG.BallColor
    ballFrame.Size = UDim2.new(0, CFG.IndicatorSize, 0, CFG.IndicatorSize)
    ballFrame.AnchorPoint = Vector2.new(0.5, 0.5)
    ballFrame.Parent = ballGui
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = ballFrame
    
    if hoopGui then hoopGui:Destroy() end
    hoopGui = Instance.new("ScreenGui")
    hoopGui.Name = "HoopInd"
    hoopGui.ResetOnSpawn = false
    hoopGui.Parent = LP:WaitForChild("PlayerGui")
    
    local hoopFrame = Instance.new("Frame")
    hoopFrame.Name = "Hoop"
    hoopFrame.BackgroundColor3 = CFG.HoopColor
    hoopFrame.Size = UDim2.new(0, CFG.IndicatorSize + 4, 0, CFG.IndicatorSize + 4)
    hoopFrame.AnchorPoint = Vector2.new(0.5, 0.5)
    hoopFrame.Parent = hoopGui
    
    local hoopCorner = Instance.new("UICorner")
    hoopCorner.CornerRadius = UDim.new(1, 0)
    hoopCorner.Parent = hoopFrame
    
    if indicatorConn then indicatorConn:Disconnect() end
    indicatorConn = RunService.RenderStepped:Connect(function()
        -- Ball
        if CFG.BallIndicator then
            pcall(function()
                local ball = nil
                for _, obj in ipairs(workspace:GetDescendants()) do
                    if obj.Name:lower():find("ball") and obj:IsA("BasePart") then
                        ball = obj
                        break
                    end
                end
                if not ball then
                    for _, obj in ipairs(character:GetDescendants()) do
                        if obj.Name:lower():find("ball") then
                            ball = obj
                            break
                        end
                    end
                end
                
                if ball then
                    local pos, on = camera:WorldToViewportPoint(ball.Position)
                    ballFrame.Visible = on
                    if on then
                        ballFrame.Position = UDim2.new(0, pos.X, 0, pos.Y)
                    end
                else
                    ballFrame.Visible = false
                end
            end)
        else
            ballFrame.Visible = false
        end
        
        -- Hoop
        if CFG.HoopIndicator then
            pcall(function()
                local hoop, dist = findNearestHoop()
                if hoop and dist < 100 then
                    local pos, on = camera:WorldToViewportPoint(hoop.Position)
                    hoopFrame.Visible = on
                    if on then
                        hoopFrame.Position = UDim2.new(0, pos.X, 0, pos.Y)
                        -- Color based on range
                        if dist > 5 and dist < 60 then
                            hoopFrame.BackgroundColor3 = Color3.fromRGB(0, 255, 0) -- Green
                        else
                            hoopFrame.BackgroundColor3 = Color3.fromRGB(255, 0, 0) -- Red
                        end
                    end
                else
                    hoopFrame.Visible = false
                end
            end)
        else
            hoopFrame.Visible = false
        end
    end)
end

local function stopIndicators()
    if indicatorConn then
        indicatorConn:Disconnect()
        indicatorConn = nil
    end
    if ballGui then ballGui:Destroy() end
    if hoopGui then hoopGui:Destroy() end
    ballGui, hoopGui = nil, nil
end

