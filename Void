local function GetClosestEnemy()
    local closest, dist = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = p.Character.HumanoidRootPart
            local humanoid = p.Character:FindFirstChildOfClass("Humanoid")
            if humanoid and humanoid.Health > 0 then
                local d = (LocalPlayer.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                if d < dist then
                    closest, dist = p, d
                end
            end
        end
    end
    return closest, dist
end

local function GetBestWeapon()
    local weapons = {"Rifle", "Pistol", "Fists"}
    for _, weaponName in pairs(weapons) do
        local tool = LocalPlayer.Character:FindFirstChild(weaponName)
        if tool then return tool end
    end
    return nil
end

local function PredictPosition(enemy, timeAhead)
    if not enemy or not enemy.Character then return nil end
    local hrp = enemy.Character.HumanoidRootPart
    local velocity = hrp.AssemblyLinearVelocity
    return hrp.Position + (velocity * timeAhead)
end

local function IsInFrontOfEnemy(enemy)
    if not enemy or not enemy.Character then return false end
    local enemyHRP = enemy.Character.HumanoidRootPart
    local myHRP = LocalPlayer.Character.HumanoidRootPart
    local direction = (myHRP.Position - enemyHRP.Position).Unit
    local facing = enemyHRP.CFrame.LookVector
    return direction:Dot(facing) > 0.5
end

Connections.HybridDesync = RunService.Heartbeat:Connect(function()
    if not Config.AntiPatch.HybridDesync then return end
    
    pcall(function()
        local hrp = LocalPlayer.Character.HumanoidRootPart
        local enemy = GetClosestEnemy()
        
        if enemy then
            local time = tick()
            local phase = math.floor(time * 20) % 3
            
            if phase == 0 then
                hrp.CFrame = hrp.CFrame * CFrame.new(0.5, 0, 0)
            elseif phase == 1 then
                hrp.CFrame = hrp.CFrame * CFrame.new(-0.5, 0, 0)
            else
                hrp.CFrame = hrp.CFrame * CFrame.new(0, 0, 0.3)
            end
            
            hrp.AssemblyLinearVelocity = Vector3.new(
                math.random(-10, 10),
                hrp.AssemblyLinearVelocity.Y,
                math.random(-10, 10)
            )
        end
    end)
end)

Connections.MicroTP = RunService.Heartbeat:Connect(function()
    if not Config.AntiPatch.MicroTP then return end
    
    pcall(function()
        local enemy, distance = GetClosestEnemy()
        if enemy and distance < 30 then
            local hrp = LocalPlayer.Character.HumanoidRootPart
            local enemyHRP = enemy.Character.HumanoidRootPart
            
            local optimalPos = enemyHRP.Position + (enemyHRP.CFrame.LookVector * -3)
            hrp.CFrame = CFrame.new(
                hrp.Position:Lerp(optimalPos, 0.3),
                enemyHRP.Position
            )
        end
    end)
end)

Connections.PhantomHit = RunService.Heartbeat:Connect(function()
    if not Config.AntiPatch.PhantomHit then return end
    
    pcall(function()
        local enemy = GetClosestEnemy()
        if enemy then
            local predictedPos = PredictPosition(enemy, 0.15)
            if predictedPos then
                local hrp = LocalPlayer.Character.HumanoidRootPart
                local tool = GetBestWeapon()
                
                if tool and tick() - LastShotTime > (WeaponCooldowns[tool.Name] or 0.5) then
                    local tempCFrame = hrp.CFrame
                    hrp.CFrame = CFrame.new(hrp.Position, predictedPos)
                    tool:Activate()
                    task.wait(0.02)
                    hrp.CFrame = tempCFrame
                    LastShotTime = tick()
                end
            end
        end
    end)
end)

