-- Farm Toggle
FarmSection:NewToggle({
    Title = "Auto Farm Brainrots",
    Description = "Automatically collect brainrots",
    Default = false,
    Callback = function(state)
        farmConfig.Enabled = state
        
        if state then
            spawn(function()
                -- Ensure desync is active for farming
                if not desyncEnabled then
                    -- Trigger god mode toggle programmatically
                    -- This would need to be implemented based on your toggle callback structure
                end
                
                while farmConfig.Enabled do
                    local folder = Workspace:FindFirstChild("ActiveBrainrots")
                    if folder then
                        local rarityFolder = folder:FindFirstChild(farmConfig.Rarity)
                        if rarityFolder then
                            local brainrots = rarityFolder:GetChildren()
                            shuffleTable(brainrots)
                            
                            for _, br in pairs(brainrots) do
                                if not farmConfig.Enabled then break end
                                
                                local prompt = Br:FindFirstChild("TakePrompt", true)
                                if Prompt then
                                    pcall(function()
                                        local root = Br:FindFirstChild("Root")
                                        if root then
                                            -- Teleport to brainrot
                                            if desyncEnabled then
                                                local char = LocalPlayer.Character
                                                if char then
                                                    local hrp = char:FindFirstChild("HumanoidRootPart")
                                                    if hrp then
                                                        -- Smooth tween to position
                                                        local targetCF = root.CFrame
                                                        local startCF = hrp.CFrame
                                                        local distance = (targetCF.Position - startCF.Position).Magnitude
                                                        local duration = math.clamp(distance / 80, 0.15, 4)
                                                        
                                                        -- Simple tween implementation
                                                        local startTime = tick()
                                                        while tick() - startTime < duration do
                                                            local alpha = (tick() - startTime) / duration
                                                            local smoothAlpha = alpha * alpha * (3 - 2 * alpha)
                                                            hrp.CFrame = startCF:Lerp(targetCF, smoothAlpha)
                                                            task.wait()
                                                        end
                                                        
                                                        fireproximityprompt(Prompt)
                                                        humanWait(80, 200)
                                                        
                                                        if math.random(1, 25) == 1 then
                                                            humanWait(350, 800)
                                                        end
                                                    end
                                                end
                                            end
                                        end
                                    end
                                    
                                    -- Return to spawn if enabled
                                    if farmConfig.AutoReturn and farmConfig.SpawnPosition then
                                        local char = LocalPlayer.Character
                                        if char then
                                            local hrp = char:FindFirstChild("HumanoidRootPart")
                                            if hrp then
                                                local returnCF = farmConfig.SpawnPosition
                                                local startCF = hrp.CFrame
                                                local distance = (returnCF.Position - startCF.Position).Magnitude
                                                local duration = math.clamp(distance / 80, 0.15, 4)
                                                
                                                local startTime = tick()
                                                while tick() - startTime < duration do
                                                    local alpha = (tick() - startTime) / duration
                                                    local smoothAlpha = alpha * alpha * (3 - 2 * alpha)
                                                    hrp.CFrame = startCF:Lerp(returnCF, smoothAlpha)
                                                    task.wait()
                                                end
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                    
                    task.wait(0.2)
                end
                
                task.wait(0.2)
            end)
        end
    end
})

