-- MAIN LOOP
-- ═══════════════════════════════════════════
RunService.RenderStepped:Connect(function(dt)
    camera = Workspace.CurrentCamera
    local center = getScreenCenter()
    local sensX, sensY = getSensitivity()

    -- FOV circles
    fovCircle.Position  = center
    fovCircle.Radius    = getEffectiveAimbotFOV()
    fovCircle.Visible   = AimbotCFG.DrawFOV and AimbotCFG.On and AimbotCFG.FOVStyle ~= "Invisible"

    saFovCircle.Position = center
    saFovCircle.Radius   = SACFG.IgnoreFOV and 0 or getEffectiveSAFOV()
    saFovCircle.Visible  = SACFG.DrawFOV and SACFG.On and not SACFG.IgnoreFOV

    -- Bullet tracer update
    updateTracers(dt)

    -- ESP
    updateESP()

    -- Aimbot
    if AimbotCFG.On and CameraController then
        if isInReaction then
            reactionTimer = reactionTimer - dt
            if reactionTimer <= 0 then isInReaction = false end
        end
        if not isInReaction then
            if lockedTarget and not isTargetValid(lockedTarget) then
                lockedTarget = nil; lockTimer = 0; resetDelayedPos()
            end
            if not lockedTarget then
                local newT = findAimbotTarget()
                if newT then
                    lockedTarget  = newT
                    lockTimer     = 0
                    isInReaction  = true
                    reactionTimer = AimbotCFG.ReactionTime / 1000
                    resetDelayedPos()
                end
            end
            if lockedTarget then
                lockTimer = lockTimer + dt
                if lockTimer > AimbotCFG.ForgotTime then
                    lockedTarget = nil; lockTimer = 0; resetDelayedPos()
                elseif isInFOV(lockedTarget) then
                    local aimPos = getDelayedPos(lockedTarget, dt)
                    if aimPos then
                        local sm = math.clamp(1 / math.max(AimbotCFG.Smoothness, 0.1) * sensX, 0.01, 1)
                        pcall(function()
                            local cp  = camera.CFrame.Position
                            local du  = (aimPos - cp).Unit
                            local tP  = math.asin(math.clamp(du.Y, -1, 1)) * sensY
                            local tY  = math.atan2(-du.X, -du.Z)
                            local cur = CameraController.Rotation
                            CameraController:SetRotation(Vector2.new(
                                cur.X + (tP - cur.X) * sm,
                                cur.Y + angleDiff(cur.Y, tY) * sm
                            ))
                        end)
                    end
                else
                    lockedTarget = nil; lockTimer = 0; resetDelayedPos()
                end
            end
        end
    end
end)

