-- // KNIFE FEATURES
-- ============================================================

-- Get closest player within range
local function GetClosestPlayer(range)
    local char = lp.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = char.HumanoidRootPart.Position
    local closest, closestDist = nil, range

    for _, plr in ipairs(p:GetPlayers()) do
        if plr ~= lp then
            local c2 = plr.Character
            if c2 and c2:FindFirstChild("HumanoidRootPart") then
                local d = (c2.HumanoidRootPart.Position - myPos).Magnitude
                if d < closestDist then
                    closest = plr
                    closestDist = d
                end
            end
        end
    end
    return closest
end

-- Get local knife attachment
local function GetKnife()
    local char = lp.Character
    if not char then return nil end
    local knife = char:FindFirstChild("Knife")
    if knife then return knife:FindFirstChild("BodyAttach") end
    return nil
end

-- Trigger a stab (fires ConnectM6D with knife attachment)
local function DoStab()
    local attach = GetKnife()
    if attach then
        pcall(function()
            ConnectM6D:FireServer(attach)
        end)
    end
end

-- Auto Stab loop — stabs closest player in range repeatedly
local function StartAutoStab()
    StopThread("knife")
    threads["knife"] = task.spawn(function()
        while cfg.knifeEnabled and cfg.knifeMode == "AutoStab" do
            local target = GetClosestPlayer(cfg.knifeRange)
            if target and target.Character then
                DoStab()
            end
            task.wait(cfg.knifeDelay)
        end
    end)
end

-- TP to Player + Stab — teleports to closest enemy then stabs
local function StartTpStab()
    StopThread("knife")
    threads["knife"] = task.spawn(function()
        while cfg.knifeEnabled and cfg.knifeMode == "TpToPlayer" do
            local target = GetClosestPlayer(999) -- no range limit for TP mode
            if target and target.Character then
                local char = lp.Character
                local g = char and char:FindFirstChild("HumanoidRootPart")
                local tg = target.Character:FindFirstChild("HumanoidRootPart")
                if g and tg then
                    -- TP slightly behind target
                    g.CFrame = tg.CFrame * CFrame.new(0, 0, 2)
                    task.wait(0.05)
                    DoStab()
                end
            end
            task.wait(cfg.knifeDelay)
        end
    end)
end

local function StartKnife()
    if cfg.knifeMode == "AutoStab" then
        StartAutoStab()
    else
        StartTpStab()
    end
end

