-- ═══════════════════════════════════════════
-- VOID DRIFT — Perlin noise based direction
-- Fractal layered noise for organic unpredictability
-- ═══════════════════════════════════════════
local function computeDriftDir(t)
    local nx, nz = 0, 0
    local amp, freq = 1, 0.0001

    -- 4 octaves of fractal noise for smooth organic direction
    for _ = 1, 4 do
        nx = nx + math.noise(t * freq, 0) * amp
        nz = nz + math.noise(0, t * freq) * amp
        freq = freq * 2.37
        amp  = amp  * 0.5
    end

    -- Low freq wander layer
    local sp = t * 0.00073
    nx = nx + math.noise(sp + 13.7,  7.3) * 0.3
    nz = nz + math.noise(sp + 31.1, 17.9) * 0.3

    -- Circular perturbation to prevent straight-line drift
    local cp = t * 0.00213
    nx = nx + math.sin(cp) * math.cos(cp * 1.618) * 0.2
    nz = nz + math.cos(cp * 0.618) * math.sin(cp * 2.718) * 0.2

    local len = math.sqrt(nx * nx + nz * nz)
    if len < 0.001 then
        local a = t * math.pi * 0.1
        return math.cos(a), math.sin(a)
    end
    return nx / len, nz / len
end

-- ═══════════════════════════════════════════
-- VOID METHOD — position computation per method
-- ═══════════════════════════════════════════
local function computeVoidPosition(dt)
    local t  = VoidState.Elapsed
    local bY = CFG.Void.YBase + VoidState.YOffset
    local m  = CFG.Void.Method

    -- Stable: no movement
    if m == "Stable" then
        return Vector3.new(VoidState.X, bY, VoidState.Z)

    -- Drift: fractal noise driven movement
    elseif m == "Drift" then
        local dx, dz = computeDriftDir(t)
        VoidState.DirX = VoidState.DirX + (dx - VoidState.DirX) * CFG.Void.DriftChaos * dt * 10
        VoidState.DirZ = VoidState.DirZ + (dz - VoidState.DirZ) * CFG.Void.DriftChaos * dt * 10
        VoidState.X    = VoidState.X + VoidState.DirX * CFG.Void.DriftSpeed * dt
        VoidState.Z    = VoidState.Z + VoidState.DirZ * CFG.Void.DriftSpeed * dt
        VoidState.YOffset = VoidState.YOffset + VoidState.YDir * CFG.Void.YDriftSpeed * dt
        if math.abs(VoidState.YOffset) >= CFG.Void.YDriftRange then
            VoidState.YDir = -VoidState.YDir
        end
        return Vector3.new(VoidState.X, CFG.Void.YBase + VoidState.YOffset, VoidState.Z)

    -- Chaotic: fully random step each frame
    elseif m == "Chaotic" then
        VoidState.X       = VoidState.X + (math.random() - 0.5) * CFG.Void.DriftSpeed * dt * 5
        VoidState.Z       = VoidState.Z + (math.random() - 0.5) * CFG.Void.DriftSpeed * dt * 5
        VoidState.YOffset = VoidState.YOffset + (math.random() - 0.5) * CFG.Void.YDriftSpeed * dt * 5
        return Vector3.new(VoidState.X, CFG.Void.YBase + VoidState.YOffset, VoidState.Z)

    -- Circle: constant radius circular orbit
    elseif m == "Circle" then
        local r = 1e9
        return Vector3.new(
            VoidState.X + math.cos(t * 2) * r,
            bY,
            VoidState.Z + math.sin(t * 2) * r
        )

    -- Spiral: expanding radius circle
    elseif m == "Spiral" then
        local r = 1e9 * (1 + math.sin(t))
        return Vector3.new(
            VoidState.X + math.cos(t * 3) * r,
            bY,
            VoidState.Z + math.sin(t * 3) * r
        )

    -- Lissajous: XZ phase-offset figure pattern
    elseif m == "Lissajous" then
        local r = 2e9
        return Vector3.new(
            VoidState.X + math.sin(t * CFG.LissajousA) * r,
            bY,
            VoidState.Z + math.sin(t * CFG.LissajousB) * r
        )

    -- Perlin Noise: smooth noise driven XZ
    elseif m == "Perlin Noise" then
        local nt = t * 0.1
        return Vector3.new(
            VoidState.X + math.noise(nt, 0) * 5e9,
            bY,
            VoidState.Z + math.noise(0, nt) * 5e9
        )

    -- Flicker: alternates between two far positions
    elseif m == "Flicker" then
        local flip = (tick() % (CFG.FlickerInterval * 2) < CFG.FlickerInterval)
        return flip
            and Vector3.new(VoidState.X, CFG.Void.YBase, VoidState.Z)
            or  Vector3.new(-VoidState.X, CFG.Void.YBase + 1e9, -VoidState.Z)

    -- Gravity Well: circular orbit with sine amplitude modulation
    elseif m == "Gravity Well" then
        local gt = t * 0.5
        local r  = CFG.GravityStr * (1 + math.sin(gt))
        return Vector3.new(
            VoidState.X + math.cos(gt) * r,
            bY + math.sin(gt * 0.7) * r,
            VoidState.Z + math.sin(gt) * r
        )

    -- Helix: circle + vertical sine wave
    elseif m == "Helix" then
        local r  = 1e9
        local ht = t * 2
        return Vector3.new(
            VoidState.X + math.cos(ht) * r,
            bY + math.sin(ht * 0.5) * r,
            VoidState.Z + math.sin(ht) * r
        )

    -- Figure 8: lemniscate
    elseif m == "Figure 8" then
        local r  = 1.5e9
        local ft = t * 1.5
        return Vector3.new(
            VoidState.X + math.sin(ft) * r,
            bY,
            VoidState.Z + math.sin(ft) * math.cos(ft) * r
        )

    -- Tornado: expanding radius with fast rotation
    elseif m == "Tornado" then
        local r  = 2e9 * math.abs(math.sin(t))
        local tt = t * 5
        return Vector3.new(
            VoidState.X + math.cos(tt) * r,
            bY + math.sin(t * 2) * 1e9,
            VoidState.Z + math.sin(tt) * r
        )

    -- Butterfly: parametric butterfly curve in 3D
    elseif m == "Butterfly" then
        local r = (math.exp(math.sin(t)) - 2 * math.cos(4 * t)
                  + math.sin((2 * t - math.pi) / 24) ^ 5) * 5e8
        return Vector3.new(
            VoidState.X + math.sin(t) * r,
            bY + math.cos(t) * r,
            VoidState.Z + math.sin(t * 0.5) * r
        )

    -- Double Helix: alternating sign helix
    elseif m == "Double Helix" then
        local r   = 1e9
        local dht = t * 3
        local off = (tick() % 1 < 0.5) and 1 or -1
        return Vector3.new(
            VoidState.X + math.cos(dht) * r * off,
            bY + math.sin(dht) * 5e8,
            VoidState.Z + math.sin(dht) * r * off
        )

    -- Chaotic Sphere: spherical parametric with two independent time vars
    elseif m == "Chaotic Sphere" then
        local r  = 2e9
        local t1 = t * 2
        local t2 = t * 1.3
        return Vector3.new(
            VoidState.X + math.sin(t1) * math.cos(t2) * r,
            bY + math.sin(t1) * math.sin(t2) * r,
            VoidState.Z + math.cos(t1) * r
        )

    -- Quantum Tunneling: random large teleport jumps
    -- Most effective for Rivals — unpredictable server reconciliation
    elseif m == "Quantum Tunneling" then
        local sign = math.random() > 0.5 and 1 or -1
        local r    = 1e11 * sign
        local jitter = Vector3.new(
            (math.random() - 0.5) * 2e9,
            (math.random() - 0.5) * 2e8,
            (math.random() - 0.5) * 2e9
        )
        return Vector3.new(VoidState.X + r, bY + jitter.Y, VoidState.Z + r) + jitter

    -- Fractal Desync: additive sine harmonics — complex waveform
    elseif m == "Fractal Desync" then
        local ft = t * 5
        local x  = math.sin(ft) + math.sin(ft * 2.1) / 2 + math.sin(ft * 3.2) / 4
        local z  = math.cos(ft) + math.cos(ft * 2.2) / 2 + math.cos(ft * 3.1) / 4
        return Vector3.new(
            VoidState.X + x * 1e10,
            bY + math.sin(ft * 10) * 1e9,
            VoidState.Z + z * 1e10
        )

    -- Extreme Desync: very fast large amplitude trig
    elseif m == "Extreme Desync" then
        local et = t * 15
        local r  = 1e12
        return Vector3.new(
            VoidState.X + math.sin(et) * r,
            bY + math.cos(et * 1.5) * r * 0.1,
            VoidState.Z + math.cos(et) * r
        )

    -- Quantum Oscillation: extremely fast oscillation
    elseif m == "Quantum Oscillation" then
        local qt = t * 50
        local r  = 1e11 * math.sin(qt)
        return Vector3.new(
            VoidState.X + r,
            bY + math.cos(qt) * 1e10,
            VoidState.Z + r
        )

    -- Frame Skip: flips between far position and base every ~5 frames
    elseif m == "Frame Skip" then
        if tick() % 0.1 < 0.05 then
            return Vector3.new(VoidState.X * 2, bY + 1e11, VoidState.Z * 2)
        end
        return Vector3.new(VoidState.X, bY, VoidState.Z)
    end

    -- Fallback
    return Vector3.new(VoidState.X, bY, VoidState.Z)
end

