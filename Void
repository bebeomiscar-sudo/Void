local origCheckFire = CheckFire.FireServer
CheckFire.FireServer = function(self, ...)
    if cfg.autoReload then
        task.delay(cfg.reloadDelay, function()
            pcall(function() ReloadRemote:FireServer() end)
        end)
    end
    return origCheckFire(self, ...)
end
