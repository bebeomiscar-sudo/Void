-- ═══════════════════════════════════════════
-- PASS SYSTEM
-- ═══════════════════════════════════════════
local passConn = nil

local function doPass()
    pcall(function()
        Remotes.Pass:FireServer()
    end)
end

local function startAutoPass()
    if passConn then passConn:Disconnect() end
    
    passConn = RunService.Heartbeat:Connect(function()
        if not CFG.AutoPass then return end
        
        if hasBall() then
            -- Find nearest teammate
            local nearestTeammate = nil
            local nearestDist = math.huge
            
            pcall(function()
                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= LP and p.Character then
                        local team = LP.Team
                        if team and p.Team == team then
                            local dist = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                            if dist < nearestDist and dist < 50 then
                                nearestDist = dist
                                nearestTeammate = p
                            end
                        end
                    end
                end
            end)
            
            if nearestTeammate and nearestDist < 30 then
                doPass()
                task.wait(0.5)
            end
        end
    end)
end

local function stopAutoPass()
    if passConn then
        passConn:Disconnect()
        passConn = nil
    end
end

