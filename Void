    Icon             = 0,
    LoadingTitle     = "Flick Script",
    LoadingSubtitle  = "Tracer + Auto Reload",
    Theme            = "Default",
    DisableBuildWarnings = true,
    ConfigurationSaving  = {Enabled=true, FolderName="FlickScript", FileName="Config"},
