-- GROUND Y SCAN
-- Used so desync spoof appears to be on the map
-- ═══════════════════════════════════════════
local function updateGroundY()
    local rp = RaycastParams.new()
    rp.FilterType = Enum.RaycastFilterType.Exclude
    if LP.Character then
        rp.FilterDescendantsInstances = { LP.Character }
    end
    local result = workspace:Raycast(Vector3.new(0, 1000, 0), Vector3.new(0, -2000, 0), rp)
    if result then
        VoidState.GroundY = result.Position.Y + 3
    end
end

-- ═══════════════════════════════════════════
-- DESYNC SPOOF POSITION
-- Wanders near character's real XZ, but Y = ground
-- Server sees brief ground-level position during flicker
-- ═══════════════════════════════════════════
local function stepSpoofPosition(dt)
    -- Lazy ground refresh every 5 seconds
    VoidState.GroundUpdateT = VoidState.GroundUpdateT + dt
    if VoidState.GroundUpdateT > 5 then
        VoidState.GroundUpdateT = 0
        task.spawn(updateGroundY)
    end

    local nv = math.noise(VoidState.Elapsed * 0.8, 42.0)
    VoidState.SpoofAngle = VoidState.SpoofAngle
        + VoidState.SpoofDir
        * (1.5 + nv * CFG.Desync.WanderChaos)
        * CFG.Desync.WanderSpeed * dt

    -- Randomly reverse wander direction
    if math.noise(VoidState.Elapsed * 0.3, 7.7) > 0.6 then
        VoidState.SpoofDir = -VoidState.SpoofDir
    end

    local r = CFG.Desync.Radius * (0.5 + 0.5 * math.abs(math.noise(VoidState.Elapsed * 0.5, 0)))

    VoidState.FakeGroundPos = Vector3.new(
        VoidState.SpoofBaseX + math.cos(VoidState.SpoofAngle) * r,
        VoidState.GroundY,
        VoidState.SpoofBaseZ + math.sin(VoidState.SpoofAngle) * r
    )
end

-- ═══════════════════════════════════════════
-- DESYNC FLICKER
-- Briefly teleports HRP to ground-level spoof position
-- Server registers a "valid" ground position → hitbox splits
-- Immediately returns to void on next frame
-- ═══════════════════════════════════════════
local function runDesyncFlicker()
    if VoidState.InFlicker then return end
    local hrp = getHRP()
    if not hrp then return end

    VoidState.InFlicker = true
    local savedVoidPos  = VoidState.IntendedPos

    -- Push to fake ground position
    pcall(function()
        hrp.CFrame = CFrame.new(VoidState.FakeGroundPos)
        hrp.AssemblyLinearVelocity = Vector3.new(0, -0.01, 0)
    end)

    -- Return to void on next physics frame
    task.delay(0, function()
        local hrp2 = getHRP()
        if hrp2 and CFG.Void.On then
            pcall(function()
                hrp2.CFrame = CFrame.new(savedVoidPos)
                hrp2.AssemblyLinearVelocity = Vector3.zero
            end)
        end
        VoidState.InFlicker = false
    end)
end

-- ═══════════════════════════════════════════
-- VOID EVASION
-- Detects nearby enemy projectiles/players via velocity prediction
-- Pushes void position away from incoming threats
-- ═══════════════════════════════════════════
local function checkVoidEvasion()
    if not CFG.Evade.On or VoidState.EvadeCooldown > 0 then return end

    local minDist   = math.huge
    local threatVec = Vector3.zero

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local vel  = hrp.AssemblyLinearVelocity
                -- Predict 0.5s ahead
                local pred = hrp.Position + vel * 0.5
                local d    = (pred - VoidState.IntendedPos).Magnitude
                if d < minDist then
                    minDist   = d
                    threatVec = (pred - VoidState.IntendedPos).Unit
                end
            end
        end
    end

    if minDist < CFG.Evade.Radius then
        -- Flee away from threat, scaled by proximity
        local esc       = -threatVec
        local threat    = clamp(1 - (minDist / CFG.Evade.Radius), 0, 1)
        local escForce  = CFG.Evade.Speed * (1 + threat * 2)

        VoidState.X = VoidState.X + esc.X * escForce
        VoidState.Z = VoidState.Z + esc.Z * escForce

        -- Vertical escape with configurable bias
        if math.random() < (CFG.Evade.VertBias + threat * 0.2) then
            local vDir = CFG.Evade.ForceUp and 1 or (math.random() > 0.5 and 1 or -1)
            VoidState.YOffset = VoidState.YOffset + vDir * CFG.Evade.Vertical
        end

        VoidState.EvadeCooldown = CFG.Evade.Cooldown * (1 - threat * 0.3)
    end
end

-- ═══════════════════════════════════════════
-- BYPASS APPLICATION
-- Applies position to HRP using selected bypass method
-- ═══════════════════════════════════════════
local function applyBypass(hrp, targetPos)
    local mode = CFG.Void.BypassMode

    if mode == "Velocity" then
        -- Move using velocity — less obvious but less accurate
        pcall(function()
            hrp.AssemblyLinearVelocity = (targetPos - hrp.Position) * 100
        end)

    elseif mode == "CFrame only" then
        -- Direct CFrame write — simplest
        pcall(function()
            hrp.CFrame = CFrame.new(targetPos)
        end)

    elseif mode == "Hybrid" then
        -- CFrame + tiny upward velocity to keep physics active
        pcall(function()
            hrp.CFrame = CFrame.new(targetPos)
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0.01, 0)
        end)

    elseif mode == "Physics Bypass" then
        -- CFrame + random velocity to confuse server interpolation
        pcall(function()
            hrp.CFrame = CFrame.new(targetPos)
            hrp.AssemblyLinearVelocity = Vector3.new(
                math.random(-1, 1),
                math.random(-1, 1),
                math.random(-1, 1)
            ) * 1e5
        end)

    else
        -- Extreme Networking (default): CFrame + zero velocities
        -- Periodically chaos-injects velocity to disrupt server reconciliation
        pcall(function()
            hrp.CFrame = CFrame.new(targetPos)
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
        end)

        -- ~1/10 chance per frame to inject velocity chaos
        if math.random(1, 10) == 1 then
            pcall(function()
                hrp.AssemblyLinearVelocity = Vector3.new(
                    (math.random() - 0.5) * 2e7,
                    (math.random() - 0.5) * 2e7,
                    (math.random() - 0.5) * 2e7
                )
            end)
        end
    end
end

-- ═══════════════════════════════════════════
-- LOCK TO VOID — main per-frame void logic
-- ═══════════════════════════════════════════
local function lockToVoid(dt)
    if VoidState.InFlicker then return end

    -- Tick evasion cooldown
    if VoidState.EvadeCooldown > 0 then
        VoidState.EvadeCooldown = VoidState.EvadeCooldown - dt
    end

    checkVoidEvasion()

    -- Compute new void position from selected method
    VoidState.IntendedPos = computeVoidPosition(dt)

    -- Anti-detect micro-jitter (non-Stable methods only)
    local targetPos = VoidState.IntendedPos
    if CFG.Void.Method ~= "Stable" then
        local mt = tick() * 1000
        targetPos = targetPos + Vector3.new(
            math.sin(mt * 0.1) * 50,
            math.sin(mt * 0.07) * 20,
            math.cos(mt * 0.13) * 50
        )
    end

    local hrp = getHRP()
    if not hrp then return end

    applyBypass(hrp, targetPos)

    -- Desync sub-system
    if CFG.Desync.On then
        stepSpoofPosition(dt)
        VoidState.DesyncTimer = VoidState.DesyncTimer + dt
        if VoidState.DesyncTimer >= CFG.Desync.Tick then
            VoidState.DesyncTimer = 0
            task.spawn(runDesyncFlicker)
        end
    end
end

-- ═══════════════════════════════════════════
-- START / STOP VOID
-- ═══════════════════════════════════════════
local function startVoid()
    if VoidState.Conn then
        VoidState.Conn:Disconnect()
        VoidState.Conn = nil
    end

    -- Try to claim network ownership
    task.spawn(function()
        local hrp = getHRP()
        if hrp then
            pcall(function() hrp:SetNetworkOwner(LP) end)
        end
        task.spawn(updateGroundY)
    end)

    -- Reset starting position to current character position
    local hrp = getHRP()
    if hrp then
        local pos = hrp.Position
        VoidState.X           = pos.X
        VoidState.Z           = pos.Z
        VoidState.IntendedPos = Vector3.new(pos.X, CFG.Void.YBase, pos.Z)
        VoidState.SpoofBaseX  = pos.X
        VoidState.SpoofBaseZ  = pos.Z
    end

    VoidState.Active = true

    VoidState.Conn = RunService.Heartbeat:Connect(function(dt)
        if not CFG.Void.On then
            VoidState.Conn:Disconnect()
            VoidState.Conn   = nil
            VoidState.Active = false
            return
        end
        VoidState.Elapsed = VoidState.Elapsed + dt
        lockToVoid(dt)
    end)
end

local function stopVoid()
    if VoidState.Conn then
        VoidState.Conn:Disconnect()
        VoidState.Conn = nil
    end
    VoidState.Active = false

    -- Return character to a safe position
    local hrp = getHRP()
    if hrp then
        pcall(function()
            hrp.CFrame = CFrame.new(VoidState.SpoofBaseX, VoidState.GroundY + 5, VoidState.SpoofBaseZ)
            hrp.AssemblyLinearVelocity = Vector3.zero
        end)
    end
end

