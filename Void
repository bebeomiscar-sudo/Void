-- =============================================
-- TARGET SELECTION
-- =============================================
local function getBestTarget()
    local camera = Workspace.CurrentCamera
    if not FighterCtrl then return nil end

    local myFighter = nil
    pcall(function() myFighter = FighterCtrl.LocalFighter end)
    if not myFighter or not isAlive(myFighter) then return nil end

    local myRoot = nil
    pcall(function() myRoot = myFighter.RootPart end)
    if not myRoot then return nil end

    local best    = nil
    local bestDist = Config.FOV == 360 and math.huge or Config.FOV

    local fighters = {}
    pcall(function()
        for _, f in pairs(FighterCtrl.Fighters) do
            table.insert(fighters, f)
        end
    end)

    for _, fighter in ipairs(fighters) do
        local ok = pcall(function()
            if fighter.Player == LocalPlayer then return end
            if not isAlive(fighter) then return end
            if Config.TeamCheck and isSameTeam(fighter.Player) then return end

            local itemName = nil
            pcall(function()
                local item = fighter.EquippedItem
                if item then itemName = item.Name end
            end)

            local model = fighter.Model
            if not model then return end

            local part = getBestPart(model, Config.TargetPart)
            if not part then return end

            if Config.VisibleCheck and not isVisible(myRoot.Position, part) then return end

            local dist
            if Config.FOV == 360 then
                -- Use world distance when FOV is 360
                dist = (myRoot.Position - part.Position).Magnitude
            else
                -- Use screen distance
                local sp, onScreen = camera:WorldToScreenPoint(part.Position)
                if not onScreen then return end
                dist = (Vector2.new(sp.X, sp.Y) - camera.ViewportSize / 2).Magnitude
            end

            if dist < bestDist then
                bestDist = dist
                best = {part = part, fighter = fighter}
            end
        end)
    end

    return best
end

-- =============================================
-- TELEPORT HELPERS
-- =============================================
local function getTeleportCFrame(targetPart, myRoot)
    local mode = Config.TeleportMode
    local dist = Config.TeleportDist

    if mode == "Point Blank" then
        -- 1 stud directly infront of target facing them
        return CFrame.lookAt(
            targetPart.Position + targetPart.CFrame.LookVector * dist,
            targetPart.Position
        )
    elseif mode == "Behind" then
        -- Behind the target
        return CFrame.lookAt(
            targetPart.Position - targetPart.CFrame.LookVector * dist,
            targetPart.Position
        )
    elseif mode == "Above" then
        -- Directly above
        return CFrame.lookAt(
            targetPart.Position + Vector3.new(0, dist, 0),
            targetPart.Position
        )
    end

    return CFrame.lookAt(
        targetPart.Position + targetPart.CFrame.LookVector * dist,
        targetPart.Position
    )
end

-- =============================================
-- RAGEBOT CORE
-- =============================================
local lastShot  = 0
local busy      = false
local shotCount = 0

RunService.Heartbeat:Connect(function()
    -- FOV circle update
    local camera = Workspace.CurrentCamera
    if camera then
        fovCircle.Position = camera.ViewportSize / 2
        fovCircle.Radius   = Config.FOV == 360 and 0 or Config.FOV
        fovCircle.Visible  = Config.DrawFOV and Config.Enabled and Config.FOV ~= 360
        fovCircle.Color    = Config.FOVColor
    end

    if not Config.Enabled then return end
    if not modulesOK then return end
    if busy then return end

    -- Get our fighter
    local myFighter = nil
    pcall(function() myFighter = FighterCtrl.LocalFighter end)
    if not myFighter or not isAlive(myFighter) then return end

    -- Get equipped item
    local item = nil
    pcall(function() item = myFighter.EquippedItem end)
    if not item then return end

    -- Check weapon blacklist
    local itemName = nil
    pcall(function() itemName = item.Name end)
    if isWeaponBlacklisted(itemName) then return end

    -- Get ObjectID
    local objectID = nil
    pcall(function() objectID = item:Get("ObjectID") end)
    if not objectID then return end

    -- Check ammo
    local ammo = nil
    pcall(function() ammo = item:Get("CurrentAmmo") end)
    if ammo ~= nil and ammo <= 0 then
        if Config.AutoReload then
            pcall(function()
                UseItemRemote:FireServer(
                    objectID,
                    EnumLib:ToEnum("Reload"),
                    {}
                )
            end)
        end
        return
    end

    -- Fire delay
    local now = tick() * 1000
    if now - lastShot < Config.FireDelay then return end
    lastShot = now

    -- Find target
    local result = getBestTarget()
    if not result then return end

    local targetPart    = result.part
    local targetFighter = result.fighter

    -- Get our root
    local myRoot = nil
    pcall(function() myRoot = myFighter.RootPart end)
    if not myRoot then return end

    busy = true

    task.spawn(function()
        local originalCF = myRoot.CFrame

        -- Teleport us to fire position
        local fireCF = getTeleportCFrame(targetPart, myRoot)
        pcall(function() myRoot.CFrame = fireCF end)

        -- Small yield so physics registers
        task.wait(0.016)

        -- Burst fire
        for i = 1, Config.BurstCount do
            if not Config.Enabled then break end

            -- Re-grab part in case they moved
            local part = targetPart
            if not part or not part.Parent then break end

            local aimCF = CFrame.lookAt(fireCF.Position, part.Position)

            local shotData = {}
            local ok = pcall(function()
                shotData[utf8.char(1)] = {
                    [utf8.char(0)] = Util:EncodeCFrame(aimCF),
                    [utf8.char(1)] = Util:EncodeCFrame(part.CFrame),
                    [utf8.char(2)] = part,
                    [utf8.char(3)] = Util:EncodeCFrame(
                        part.CFrame:ToObjectSpace(CFrame.new(part.Position))
                    ),
                }
            end)

            if ok then
                pcall(function()
                    UseItemRemote:FireServer(
                        objectID,
                        EnumLib:ToEnum("StartShooting"),
                        shotData,
                        nil
                    )
                end)

                task.wait(0.06)

                pcall(function()
                    UseItemRemote:FireServer(
                        objectID,
                        EnumLib:ToEnum("StopShooting"),
                        {},
                        nil
                    )
                end)

                showHitEffect()
            end

            if i < Config.BurstCount then
                task.wait(Config.BurstDelay / 1000)
            end
        end

        -- Teleport back instantly
        pcall(function() myRoot.CFrame = originalCF end)

        busy = false
    end)
end)

