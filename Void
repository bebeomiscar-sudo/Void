--  FEATURE 3 — ESP
--  Box (SelectionBox), health bar (BillboardGui), name tag, tracer lines
-- ═══════════════════════════════════════════════════════════════════════════════
local ESP = {
    boxes      = false,
    healthbar  = false,
    names      = false,
    tracers    = false,
    teamcheck  = true,
    boxColor   = Color3.fromRGB(255, 60, 60),
    tracerColor = Color3.fromRGB(255, 60, 60),
    tracerThick = 1.5,
    tracerDur   = 0.3,
}

local espData    = {}    -- [player] = { box, billboard, tracer }
local tracerPool = {}

local espFolder = Instance.new("Folder")
espFolder.Name   = "ESP"
espFolder.Parent = Workspace

local function removeESP(p)
    local d = espData[p]
    if not d then return end
    if d.box       then d.box:Destroy() end
    if d.billboard then d.billboard:Destroy() end
    espData[p] = nil
end

local function buildESP(p)
    if p == lp then return end
    local c = p.Character
    if not c then return end
    removeESP(p)
    local d = {}

    if ESP.boxes then
        local b = Instance.new("SelectionBox")
        b.Color3              = ESP.boxColor
        b.LineThickness       = 0.04
        b.SurfaceTransparency = 1
        b.Adornee             = c
        b.Parent              = espFolder
        d.box = b
    end

    if ESP.healthbar or ESP.names then
        local bb = Instance.new("BillboardGui")
        bb.Size            = UDim2.new(0, 120, 0, 40)
        bb.StudsOffset     = Vector3.new(0, 3.2, 0)
        bb.AlwaysOnTop     = true
        bb.Adornee         = c:FindFirstChild("Head") or c:FindFirstChild("HumanoidRootPart")
        bb.Parent          = espFolder

        if ESP.names then
            local lbl = Instance.new("TextLabel", bb)
            lbl.Size                = UDim2.new(1, 0, 0.5, 0)
            lbl.BackgroundTransparency = 1
            lbl.TextColor3          = Color3.fromRGB(255,255,255)
            lbl.TextStrokeTransparency = 0.4
            lbl.Font                = Enum.Font.GothamBold
            lbl.TextScaled          = true
            lbl.Text                = p.Name
            d.namelbl = lbl
        end

        if ESP.healthbar then
            local hm = c:FindFirstChildOfClass("Humanoid")
            local bar = Instance.new("Frame", bb)
            bar.Size              = UDim2.new(1, 0, 0.35, 0)
            bar.Position          = UDim2.new(0, 0, 0.6, 0)
            bar.BackgroundColor3  = Color3.fromRGB(30,30,30)
            bar.BorderSizePixel   = 0
            local fill = Instance.new("Frame", bar)
            fill.BackgroundColor3 = Color3.fromRGB(80, 220, 80)
            fill.BorderSizePixel  = 0
            fill.Size = UDim2.new(hm and (hm.Health / math.max(hm.MaxHealth,1)) or 1, 0, 1, 0)
            d.healthfill = fill
            d.healthhm   = hm
        end

        d.billboard = bb
    end

    espData[p] = d
end

local function updateESPFrame()
    for _, p in ipairs(Players:GetPlayers()) do
        if p == lp then continue end
        if ESP.teamcheck and sameteam(p) then
            removeESP(p); continue
        end
        local c  = p.Character
        local hm = c and c:FindFirstChildOfClass("Humanoid")
        if not c or not hm or hm.Health <= 0 then
            removeESP(p); continue
        end
        local d = espData[p]
        if not d then
            buildESP(p); d = espData[p]
        end
        if d and d.healthfill and d.healthhm then
            local pct = math.clamp(d.healthhm.Health / math.max(d.healthhm.MaxHealth,1), 0, 1)
            d.healthfill.Size = UDim2.new(pct, 0, 1, 0)
            d.healthfill.BackgroundColor3 = Color3.fromHSV(pct * 0.33, 0.9, 0.9)
        end
    end
end

-- tracer spawning (called from fireshot wrapper)
local function spawnTracer(from3, to3)
    if not ESP.tracers then return end
    local l = Drawing.new("Line")
    l.Thickness    = ESP.tracerThick
    l.Color        = ESP.tracerColor
    l.Transparency = 0
    l.Visible      = false
    table.insert(tracerPool, { line=l, born=tick(), from=from3, to=to3 })
end

local function w2s(p3)
    local sp, on = cam:WorldToViewportPoint(p3)
    if not on or sp.Z <= 0 then return nil end
    return Vector2.new(sp.X, sp.Y)
end

local function updateTracers()
    local now   = tick()
    local alive = {}
    for _, t in ipairs(tracerPool) do
        local age  = now - t.born
        local life = math.max(ESP.tracerDur, 0.05)
        if age >= life then
            pcall(function() t.line:Remove() end)
        else
            local a  = 1 - age / life
            local f2 = Vector2.new(cam.ViewportSize.X * 0.5, cam.ViewportSize.Y)
            local t2 = w2s(t.to)
            if t2 then
                t.line.From         = f2
                t.line.To           = t2
                t.line.Transparency = 1 - a
                t.line.Visible      = true
            else
                t.line.Visible = false
            end
            table.insert(alive, t)
        end
    end
    tracerPool = alive
end

-- wrap fireshot to add tracer
local _origFireShot = fireshot
fireshot = function(bp, origin)
    if ESP.tracers and bp then
        spawnTracer(origin or (ch and gethrp(ch) and gethrp(ch).Position) or Vector3.zero, bp.Position)
    end
    _origFireShot(bp, origin)
end

-- ═══════════════════════════════════════════════════════════════════════════════
--  FEATURE 4 — PREDICTION AIM ASSIST
--  Velocity-extrapolated targeting fed into fireshot
--  Does not move your camera — purely modifies the shot destination
-- ═══════════════════════════════════════════════════════════════════════════════
local PRED = {
    enabled   = false,
    strength  = 0.12,   -- seconds to lead target by
    teamcheck = true,
    fov       = 300,    -- screen radius; 0 = infinite
    priority  = "Closest",
    part      = "Head",
}

local predHistory = {}  -- [player] = { pos, tick }

local function getPredictedPart(char, partName)
    local p = char:FindFirstChild(partName)
        or char:FindFirstChild("HumanoidRootPart")
    return p
end

local function predictedPos(p, pt)
    local now = tick()
    local h   = predHistory[p]
    local pos = pt.Position
    if h and (now - h.t) > 0 then
        local vel = (pos - h.pos) / (now - h.t)
        pos = pos + vel * PRED.strength
    end
    predHistory[p] = { pos = pt.Position, t = now }
    return pos
end

local predConn = nil
local function stopPred()
    if predConn then predConn:Disconnect(); predConn = nil end
end
local function startPred()
    stopPred()
    predConn = RunService.Heartbeat:Connect(function()
        if not PRED.enabled then return end
        local myhrp = ch and gethrp(ch)
        if not myhrp then return end

        local vp     = cam.ViewportSize
        local center = Vector2.new(vp.X * 0.5, vp.Y * 0.5)
        local fov    = PRED.fov

        local enemies = sortedEnemies(PRED.priority, PRED.teamcheck)
        for _, e in ipairs(enemies) do
            local pt = getPredictedPart(e.char, PRED.part)
            if not pt then continue end
            if fov > 0 then
                local sp, on = cam:WorldToViewportPoint(pt.Position)
                if not on then continue end
                if (Vector2.new(sp.X, sp.Y) - center).Magnitude > fov then continue end
            end
            -- just update history so when fireshot fires it leads correctly
            predictedPos(e.player, pt)
            break
        end
    end)
end

-- override fireshot destination when PRED.enabled
local _origFireShot2 = fireshot
fireshot = function(bp, origin)
    if PRED.enabled and bp then
        local p    = Players:GetPlayerFromCharacter(bp.Parent)
        local pos  = bp.Position
        if p then
            local h = predHistory[p]
            local now = tick()
            if h and (now - h.t) > 0 then
                local vel = (bp.Position - h.pos) / (now - h.t)
                pos = bp.Position + vel * PRED.strength
            end
        end
        -- create a fake part at predicted position
        local fake = Instance.new("Part")
        fake.Anchored   = true
        fake.CanCollide = false
        fake.Size       = Vector3.new(0.1,0.1,0.1)
        fake.CFrame     = CFrame.new(pos)
        fake.Parent     = Workspace
        _origFireShot2(fake, origin)
        fake:Destroy()
        return
    end
    _origFireShot2(bp, origin)
end

