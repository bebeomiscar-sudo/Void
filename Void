local function clamp(x,a,b) return x<a and a or x>b and b or x end
local function getHRP()
    local c=LP.Character; return c and c:FindFirstChild("HumanoidRootPart")
end
local function getHum()
    local c=LP.Character; return c and c:FindFirstChildOfClass("Humanoid")
end

local function getClosestPlayer(maxFOV)
    local bestPlayer = nil
    local bestDist   = math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end
        if not p.Character then continue end
        local hrp = p.Character:FindFirstChild("HumanoidRootPart")
        local hum = p.Character:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum or hum.Health <= 0 then continue end

        local screenPos, onScreen = Camera:WorldToScreenPoint(hrp.Position)
        if not onScreen then continue end

        local dist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
        if dist < bestDist and dist < (maxFOV or math.huge) then
            bestDist   = dist
            bestPlayer = p
        end
    end
    return bestPlayer, bestDist
end

local function getBone(char, bone)
    if not char then return nil end
    return char:FindFirstChild(bone) or
           char:FindFirstChild("HumanoidRootPart") or
           char:FindFirstChild("Head")
end

