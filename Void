local utility = require(ReplicatedStorage.Modules.Utility)
local originalRaycast = utility.Raycast

utility.Raycast = function(...)
    local args = {...}
    
    if Config.SilentAim.Enabled and args[4] == 999 then
        local enemy = GetClosestEnemy()
        
        if enemy then
            local hitChance = math.random(100)
            if hitChance <= Config.SilentAim.HitChance then
                local targetPos = PredictPosition(enemy, Config.SilentAim.Prediction)
                if targetPos then
                    args[3] = targetPos
                end
            end
        end
    end
    
    return originalRaycast(...)
end

