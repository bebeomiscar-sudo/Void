-- Slider helper
local function AddSlider(parent, label, min, max, default, suffix, callback)
    local row = AddRow(parent, 52)
    local topLbl = Instance.new("TextLabel")
    topLbl.BackgroundTransparency = 1
    topLbl.Size = UDim2.new(1,-10,0,20)
    topLbl.Position = UDim2.new(0,10,0,2)
    topLbl.Text = label..": "..default..(suffix or "")
    topLbl.TextSize = 12
    topLbl.TextColor3 = COL_TEXT
    topLbl.Font = Enum.Font.Gotham
    topLbl.TextXAlignment = Enum.TextXAlignment.Left
    topLbl.Parent = row

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1,-20,0,6)
    track.Position = UDim2.new(0,10,0,30)
    track.BackgroundColor3 = COL_BTN
    track.BorderSizePixel = 0
    track.Parent = row
    rc(track, 3)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((default-min)/(max-min),0,1,0)
    fill.BackgroundColor3 = COL_ACCENT
    fill.BorderSizePixel = 0
    fill.Parent = track
    rc(fill, 3)

    local knob = Instance.new("TextButton")
    knob.Size = UDim2.new(0,14,0,14)
    knob.AnchorPoint = Vector2.new(0.5,0.5)
    knob.Position = UDim2.new((default-min)/(max-min),0,0.5,0)
    knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
    knob.Text = ""
    knob.BorderSizePixel = 0
    knob.Parent = track
    rc(knob, 7)

    local dragging = false
    local function update(x)
        local abs = track.AbsolutePosition.X
        local w   = track.AbsoluteSize.X
        local pct = math.clamp((x - abs) / w, 0, 1)
        local val = math.floor(min + (max-min)*pct + 0.5)
        fill.Size = UDim2.new(pct,0,1,0)
        knob.Position = UDim2.new(pct,0,0.5,0)
        topLbl.Text = label..": "..val..(suffix or "")
        callback(val)
    end

    knob.MouseButton1Down:Connect(function() dragging=true end)
    knob.TouchLongPress:Connect(function() dragging=true end)
    uis.InputChanged:Connect(function(inp)
        if dragging and (inp.UserInputType==Enum.UserInputType.MouseMovement
            or inp.UserInputType==Enum.UserInputType.Touch) then
            update(inp.Position.X)
        end
    end)
    uis.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1
            or inp.UserInputType==Enum.UserInputType.Touch then
            dragging=false
        end
    end)
    track.InputBegan:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1
            or inp.UserInputType==Enum.UserInputType.Touch then
            update(inp.Position.X)
        end
    end)
end

