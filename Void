-- Brainrot ESP
local brainrotESPObjects = {}
local rarityColors = {
    Common    = Color3.fromRGB(200, 200, 200),
    Uncommon  = Color3.fromRGB(0, 255, 0),
    Rare      = Color3.fromRGB(0, 150, 255),
    Epic      = Color3.fromRGB(150, 0, 255),
    Legendary = Color3.fromRGB(255, 170, 0),
    Mythical  = Color3.fromRGB(255, 0, 0),
    Secret    = Color3.fromRGB(255, 0, 255),
    Cosmic    = Color3.fromRGB(0, 255, 255),
    Celestial = Color3.fromRGB(255, 255, 0)
}

local function updateBrainrotESP()
    -- Clear existing
    for _, obj in pairs(brainrotESPObjects) do
        pcall(function() Obj:Destroy() end)
    end
    brainrotESPObjects = {}
    
    if not espConfig.BrainrotESP then return end
    
    local folder = Workspace:FindFirstChild("ActiveBrainrots")
    if not folder then return end
    
    local rarityFolder = folder:FindFirstChild(espConfig.BrainrotRarity)
    if not rarityFolder then return end
    
    for _, Br in pairs(rarityFolder:GetChildren()) do
        local root = Br:FindFirstChild("Root")
        if not root then continue end
        
        local color = rarityColors[espConfig.BrainrotRarity] or Color3.new(1, 1, 1)
        
        local espFolder = Instance.new("Folder")
        espFolder.Name = Br.Name .. "_ESP"
        espFolder.Parent = Br
        
        table.insert(brainrotESPObjects, espFolder)
        
        local highlight = Instance.new("Highlight")
        highlight.Adornee = Br
        highlight.FillColor = color
        highlight.OutlineColor = color
        highlight.FillTransparency = 0.5
        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
        highlight.Parent = espFolder
        
        local nameGui = Instance.new("BillboardGui")
        nameGui.Adornee = root
        nameGui.Size = UDim2.new(0, 80, 0, 20)
        nameGui.StudsOffset = Vector3.new(0, 3, 0)
        nameGui.AlwaysOnTop = true
        nameGui.Parent = espFolder
        
        local nameText = Instance.new("TextLabel")
        nameText.Size = UDim2.new(1, 0, 1, 0)
        nameText.BackgroundTransparency = 1
        nameText.TextColor3 = color
        nameText.Text = espConfig.BrainrotRarity
        nameText.Font = Enum.Font.GothamBold
        nameText.TextSize = 12
        nameText.Parent = nameGui
    end
end

BrainrotESPSection:NewToggle({
    Title = "Brainrot ESP",
    Description = "See brainrots through walls",
    Default = false,
    Callback = function(state)
        espConfig.BrainrotESP = state
        updateBrainrotESP()
        
        if state then
            Workspace.DescendantAdded:Connect(function(obj)
                if not espConfig.BrainrotESP then return end
                task.wait(0.1)
                local par = obj.Parent
                if par and par.Parent and par.Parent.Name == "ActiveBrainrots" and par.Name == espConfig.BrainrotRarity then
