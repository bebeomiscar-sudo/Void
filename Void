    Callback=function(v) cfg.tracerWidth=v/100 end})

TabT:CreateSlider({Name="Tracer Duration", Range={5,100}, Increment=5,
    Suffix="ms", CurrentValue=25, Flag="TracerDuration",
    Callback=function(v) cfg.tracerDuration=v/100 end})

TabT:CreateDropdown({
    Name = "Tracer Material",
    Options = {"Neon", "SmoothPlastic", "Glass", "ForceField"},
    CurrentOption = {"Neon"},
    Flag = "TracerMat",
    Callback = function(opt)
        cfg.tracerMaterial = Enum.Material[opt[1]]
    end,
})

TabT:CreateSection("Impact Flash")
TabT:CreateLabel("Impact flash uses the game's ExpColor automatically.")

-- ── Tab: Auto Reload ─────────────────────────────────────────
local TabR = W:CreateTab("🔄 Auto Reload", 4483345998)

TabR:CreateToggle({Name="Enable Auto Reload", CurrentValue=true, Flag="AutoReload",
    Callback=function(v) cfg.autoReload=v; UpdateStatus() end})

TabR:CreateSlider({Name="Reload Delay After Shot", Range={0,20}, Increment=1,
    Suffix="ms", CurrentValue=1, Flag="ReloadDelay",
    Callback=function(v) cfg.reloadDelay=v/100 end})

TabR:CreateSection("Manual")
TabR:CreateButton({Name="🔄 Reload Now", Callback=function()
    pcall(function() ReloadRemote:FireServer() end)
    Rayfield:Notify({Title="🔄 Reloaded", Content="Manual reload fired!", Duration=2})
end})

-- ── Tab: Mobile ───────────────────────────────────────────────
if isMobile then
    -- Quick toggle button for tracer
    local btn = Instance.new("TextButton")
    btn.Size             = UDim2.new(0,65,0,65)
    btn.Position         = UDim2.new(1,-80,1,-90)
    btn.BackgroundColor3 = Color3.fromRGB(0,200,150)
    btn.BackgroundTransparency = 0.2
    btn.Text             = "💥"
    btn.TextSize         = 28
    btn.Font             = Enum.Font.GothamBold
    btn.BorderSizePixel  = 0
    btn.ZIndex           = 10
    btn.Parent           = sg
    Instance.new("UICorner",btn).CornerRadius = UDim.new(1,0)

    btn.TouchTap:Connect(function()
        cfg.tracerEnabled = not cfg.tracerEnabled
        btn.BackgroundColor3 = cfg.tracerEnabled
            and Color3.fromRGB(0,200,150)
            or  Color3.fromRGB(200,50,50)
        UpdateStatus()
    end)
end

-- ============================================================
-- // Ready
-- ============================================================
UpdateStatus()
Rayfield:Notify({
    Title   = "💥 Flick Script",
    Content = "Tracer + Auto Reload loaded! Shoot to see tracers.",
    Duration = 5,
})

print("[FlickScript] Loaded")
