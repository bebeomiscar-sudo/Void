-- // KNIFE LOGIC
-- ============================================================
local function GetKnife()
    local char = lp.Character
    if not char then return nil end
    local knife = char:FindFirstChild("Knife")
    return knife and knife:FindFirstChild("BodyAttach") or nil
end

local function GetClosestPlayer(range)
    local char = lp.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = char.HumanoidRootPart.Position
    local closest, closestDist = nil, range
    for _, plr in ipairs(p:GetPlayers()) do
        if plr ~= lp then
            local c2 = plr.Character
            if c2 and c2:FindFirstChild("HumanoidRootPart") then
                local d = (c2.HumanoidRootPart.Position - myPos).Magnitude
                if d < closestDist then closest=plr; closestDist=d end
            end
        end
    end
    return closest
end

local function DoStab()
    local attach = GetKnife()
    if attach then pcall(function() ConnectM6D:FireServer(attach) end) end
end

local function StartAutoStab()
    StopThread("knife")
    threads["knife"] = task.spawn(function()
        while cfg.knifeEnabled and cfg.knifeMode=="AutoStab" do
            if GetClosestPlayer(cfg.knifeRange) then DoStab() end
            task.wait(cfg.knifeDelay)
        end
    end)
end

local function StartTpStab()
    StopThread("knife")
    threads["knife"] = task.spawn(function()
        while cfg.knifeEnabled and cfg.knifeMode=="TpToPlayer" do
            local target = GetClosestPlayer(999)
            if target and target.Character then
                local char = lp.Character
                local g = char and char:FindFirstChild("HumanoidRootPart")
                local tg = target.Character:FindFirstChild("HumanoidRootPart")
                if g and tg then
                    g.CFrame = tg.CFrame * CFrame.new(0,0,2)
                    task.wait(0.05)
                    DoStab()
                end
            end
            task.wait(cfg.knifeDelay)
        end
    end)
end

function StartKnife()
    if cfg.knifeMode=="AutoStab" then StartAutoStab()
    else StartTpStab() end
end

