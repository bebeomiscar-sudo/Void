-- ═══════════════════════════════════════════
-- SHOOT SYSTEM (Auto Green)
-- ═══════════════════════════════════════════
local shootConn = nil

local function calculateGreenPower(dist)
    if CFG.AutoGreen then
        -- Calculate perfect power
        if dist < 10 then
            return 65
        elseif dist < 20 then
            return 72
        elseif dist < 30 then
            return 78
        elseif dist < 40 then
            return 85
        elseif dist < 50 then
            return 92
        else
            return 100
        end
    else
        return CFG.ShootPower
    end
end

local function doShoot(power)
    local args = {
        true,
        power or CFG.ShootPower,
        [4] = false
    }
    pcall(function()
        Remotes.Shoot:FireServer(unpack(args))
    end)
end

local function startAutoShoot()
    if shootConn then shootConn:Disconnect() end
    
    shootConn = RunService.Heartbeat:Connect(function()
        if not CFG.AutoShoot then return end
        
        if not hasBall() then return end
        
        local hoop, dist = findNearestHoop()
        if not hoop then return end
        
        -- Range check
        if dist < 5 or dist > 60 then return end
        
        -- Calculate power
        local power = calculateGreenPower(dist)
        
        -- Check facing hoop
        local facing = false
        pcall(function()
            local toHoop = (hoop.Position - hrp.Position).Unit
            facing = toHoop:Dot(hrp.CFrame.LookVector) > 0.6
        end)
        
        if facing or dist < 15 then
            doShoot(power)
            task.wait(0.8)
        end
    end)
end

local function stopAutoShoot()
    if shootConn then
        shootConn:Disconnect()
        shootConn = nil
    end
end

-- ═══════════════════════════════════════════
-- SPEED BOOST
-- ═══════════════════════════════════════════
local speedConn = nil

local function applySpeedBoost()
    pcall(function()
        if humanoid then
            humanoid.WalkSpeed = CFG.WalkSpeed
            humanoid.JumpPower = CFG.JumpPower
        end
    end)
end

local function startSpeedBoost()
    if speedConn then speedConn:Disconnect() end
    applySpeedBoost()
    
    speedConn = RunService.Heartbeat:Connect(function()
        if not CFG.SpeedBoost then return end
        pcall(function()
            if humanoid then
                if humanoid.WalkSpeed ~= CFG.WalkSpeed then
                    humanoid.WalkSpeed = CFG.WalkSpeed
                end
                if humanoid.JumpPower ~= CFG.JumpPower then
                    humanoid.JumpPower = CFG.JumpPower
                end
            end
        end)
    end)
end

local function stopSpeedBoost()
    if speedConn then
        speedConn:Disconnect()
        speedConn = nil
    end
    pcall(function()
        if humanoid then
            humanoid.WalkSpeed = 16
            humanoid.JumpPower = 50
        end
    end)
end

