        local predictedPos = bone.Position
        if hrp then
            predictedPos = predictedPos + hrp.AssemblyLinearVelocity * CFG.SILENT_AIM_PREDICTION
        end

        -- Store predicted pos for silent aim intercept
        _G.SilentAimTarget = predictedPos
    end)
