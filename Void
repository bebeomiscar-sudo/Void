-- Utility functions
local function safeTeleport(character, destination)
    if not (character and destination) then return false end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not (hrp and humanoid and humanoid.Health > 0) then return false end
    
    local oldHealth = humanoid.Health
    humanoid.Health = math.huge
    
    for _, part in pairs(character:GetDescendants()) do
        if part:IsA("BasePart") then part.CanCollide = false end
    end
    
    hrp.CFrame = destination + Vector3.new(0, 5, 0)
    hrp.Velocity = Vector3.zero
    hrp.AssemblyLinearVelocity = Vector3.zero
    
    task.wait(0.2)
    humanoid.Health = oldHealth
    
    -- Restore collision
    task.spawn(function()
        task.wait(0.1)
        for _, part in pairs(character:GetDescendants()) do
            if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                part.CanCollide = true
            end
        end
    end)
    
    return true
end

local function humanWait(minMs, maxMs)
    task.wait(math.random(minMs, maxMs) / 1000)
end

local function shuffleTable(t)
    for i = #t, 2, -1 do
        local j = math.random(1, i)
        t[i], t[j] = t[j], t[i]
    end
    return t
end

