-- ============================================================
local function DrawTracer(origin, endpoint, color)
    local c = cfg.useGameColor and color or cfg.tracerColor
    local dist = (endpoint - origin).Magnitude
    if dist < 0.5 then return end
    local beam = Instance.new("Part")
    beam.Anchored=true; beam.CanCollide=false; beam.CastShadow=false
    beam.Material=cfg.tracerMaterial; beam.Color=c
    beam.Size=Vector3.new(cfg.tracerWidth,cfg.tracerWidth,dist)
    beam.CFrame=CFrame.new(origin,endpoint)*CFrame.new(0,0,-dist/2)
    beam.Parent=workspace
    local t=0; local conn
    conn=run.Heartbeat:Connect(function(dt)
        t=t+dt
        beam.Transparency=t/cfg.tracerDuration
        if t>=cfg.tracerDuration then conn:Disconnect(); beam:Destroy() end
    end)
end

local function DrawFlash(pos, color)
    local f=Instance.new("Part")
    f.Anchored=true; f.CanCollide=false; f.Material=Enum.Material.Neon
    f.Color=color or cfg.tracerColor; f.Shape=Enum.PartType.Ball
    f.Size=Vector3.one*0.5; f.Position=pos; f.Parent=workspace
    local t=0; local conn
    conn=run.Heartbeat:Connect(function(dt)
        t=t+dt; local a=t/0.15
        f.Transparency=a; f.Size=Vector3.one*(0.5+a*0.5)
        if a>=1 then conn:Disconnect(); f:Destroy() end
    end)
end

-- Hook YOUR shots via CheckShot.FireServer
local origCheckShotFire = CheckShot.FireServer
CheckShot.FireServer = function(self, ...)
    if cfg.tracerEnabled then
        local args = {...}
        local originCF  = args[5]
        local endpointV = args[6]
        if typeof(originCF)=="CFrame" and endpointV then
            local ep = typeof(endpointV)=="Vector3"
                and endpointV
                or Vector3.new(endpointV.X, endpointV.Y, endpointV.Z)
            DrawTracer(originCF.Position, ep, cfg.tracerColor)
        end
    end
    return origCheckShotFire(self, ...)
end

-- Enemy tracers
ProjectileRender.OnClientEvent:Connect(function(data)
    if not cfg.tracerEnabled or type(data)~="table" then return end
    local o,e,c = data.Origin, data.Endpoint, data.LaserColor or cfg.tracerColor
    if o and e then
        DrawTracer(Vector3.new(o.X,o.Y,o.Z), Vector3.new(e.X,e.Y,e.Z), c)
    end
end)

ProjectileFinished.OnClientEvent:Connect(function(data)
    if not cfg.tracerEnabled or type(data)~="table" then return end
    if data.CFrame then DrawFlash(data.CFrame.Position, data.ExpColor or data.LaserColor) end
end)

