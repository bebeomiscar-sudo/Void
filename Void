local function getMousePosition()
    local pos  = UIS:GetMouseLocation()
    local offX = InputCFG.Platform == "PC" and InputCFG.PC_OffsetX or InputCFG.MB_OffsetX
    local offY = InputCFG.Platform == "PC" and InputCFG.PC_OffsetY or InputCFG.MB_OffsetY
    return Vector2.new(pos.X + offX, pos.Y + offY)
end

local function getSensitivity()
