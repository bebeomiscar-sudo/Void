-- GUN MODS
-- ═══════════════════════════════════════════
local gunOriginals = {}
local gunPatchBusy = false
local EXCLUDED_GUNS = {Sniper = true, Crossbow = true, Bow = true, RPG = true}

local function patchGun()
    if gunPatchBusy then return end
    gunPatchBusy = true
    task.defer(function()
        local ok, Items = pcall(function()
            return require(ReplicatedStorage.Modules.ItemLibrary).Items
        end)
        if ok and Items then
            for name, data in pairs(Items) do
                if typeof(data) ~= "table" or EXCLUDED_GUNS[name] then continue end
                if not gunOriginals[name] then
                    gunOriginals[name] = {
                        ShootSpread        = data.ShootSpread,
                        ShootAccuracy      = data.ShootAccuracy,
                        ShootRecoil        = data.ShootRecoil,
                        ShootCooldown      = data.ShootCooldown,
                        ShootBurstCooldown = data.ShootBurstCooldown,
                    }
                end
                local orig = gunOriginals[name]
                if data.ShootSpread        then data.ShootSpread        = GunCFG.NoSpread  and 0    or orig.ShootSpread        end
                if data.ShootAccuracy      then data.ShootAccuracy      = GunCFG.NoSpread  and 0    or orig.ShootAccuracy      end
                if data.ShootRecoil        then data.ShootRecoil        = GunCFG.NoRecoil  and 0    or orig.ShootRecoil        end
                if data.ShootCooldown      then data.ShootCooldown      = GunCFG.FastShoot and 0.05 or orig.ShootCooldown      end
                if data.ShootBurstCooldown then data.ShootBurstCooldown = GunCFG.FastShoot and 0.05 or orig.ShootBurstCooldown end
            end
        end
        gunPatchBusy = false
    end)
end

-- ═══════════════════════════════════════════
-- BULLET TRACERS — Drawing.new("Line")
--
-- How it works:
-- Hook Workspace:Raycast (same hook SA uses)
-- When a raycast fires that looks like a shot
-- (from near camera/HRP, long direction),
-- draw a line from origin to hit point or
-- max range in that direction.
-- Lines fade out over TracerCFG.Duration seconds.
-- ═══════════════════════════════════════════
local TracerCFG = {
    Enabled   = false,
    Color     = Color3.fromRGB(255, 50, 50),
    Thickness = 1.5,
    Duration  = 0.4,    -- seconds before line fades
    MaxLength = 500,    -- stud cap on tracer length
}

-- Pool of active tracer lines
local activeTracers = {}  -- {line, born, fromV2, toV2}
local tracerHooked  = false

-- Convert 3D world position to 2D screen
local function worldToScreen(pos)
    local sp, on = camera:WorldToViewportPoint(pos)
    if not on or sp.Z <= 0 then return nil end
    return Vector2.new(sp.X, sp.Y)
end

local function spawnTracer(originPos, endPos)
    if not TracerCFG.Enabled then return end
    local fromV2 = worldToScreen(originPos)
    local toV2   = worldToScreen(endPos)
    if not fromV2 or not toV2 then return end

    local line = Drawing.new("Line")
    line.From        = fromV2
    line.To          = toV2
    line.Color       = TracerCFG.Color
    line.Thickness   = TracerCFG.Thickness
    line.Transparency = 0
    line.Visible     = true

    table.insert(activeTracers, {
        line    = line,
        born    = tick(),
        origin  = originPos,
        endPos  = endPos,
    })
end

-- Updated every RenderStepped — fade + cleanup
local function updateTracers(dt)
    local now   = tick()
    local alive = {}
    for _, t in ipairs(activeTracers) do
        local age  = now - t.born
        local life = TracerCFG.Duration
        if age >= life then
            t.line:Remove()
        else
            -- Recalculate screen positions each frame
            -- so they follow world correctly
            local fromV2 = worldToScreen(t.origin)
            local toV2   = worldToScreen(t.endPos)
            if fromV2 and toV2 then
                local alpha = 1 - (age / life)
                t.line.From          = fromV2
                t.line.To            = toV2
                t.line.Transparency  = 1 - alpha  -- 0=opaque 1=invisible
                t.line.Color         = TracerCFG.Color
                t.line.Thickness     = TracerCFG.Thickness
                t.line.Visible       = true
                table.insert(alive, t)
            else
                t.line.Visible = false
                table.insert(alive, t)
            end
        end
    end
    activeTracers = alive
end

local function clearTracers()
    for _, t in ipairs(activeTracers) do
        pcall(function() t.line:Remove() end)
    end
    activeTracers = {}
end

-- Hook Workspace:Raycast to detect shots for tracers
-- We piggyback on the SA hook since only one
-- hookmetamethod per namecall is allowed.
-- Instead we store a callback the hook calls.
local tracerRayCallback = nil

local function applyTracerHook()
    if tracerHooked then return end
    if not hookmetamethod then return end
    -- Only apply if SA hook is NOT already applied
    -- (if SA hook is applied, tracers get injected into SA callback instead)
    if saHookApplied then
        -- Inject into SA callback path
        tracerHooked = true
        return
    end

    local origNC
    origNC = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
        local method = getnamecallmethod()
        if method == "Raycast" and (self == Workspace or self == ws) then
            local result = origNC(self, ...)
            -- Fire tracer callback if enabled
            if TracerCFG.Enabled and tracerRayCallback then
                local args = {...}
                tracerRayCallback(args[1], args[2], result)
            end
            return result
        end
        return origNC(self, ...)
    end))
    tracerHooked = true
end

-- Tracer ray callback — called when any Workspace:Raycast fires
tracerRayCallback = function(origin, direction, result)
    if not TracerCFG.Enabled then return end
    if not origin or not direction then return end
    if typeof(origin) ~= "Vector3" or typeof(direction) ~= "Vector3" then return end
    -- Only care about long rays (shots, not camera rays)
    if direction.Magnitude < 30 then return end

    local myChar = LP.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
    local camPos = camera.CFrame.Position

    -- Check if ray originates near camera or HRP
    local nearCam = (origin - camPos).Magnitude < 20
    local nearHRP = myHRP and (origin - myHRP.Position).Magnitude < 15 or false
    if not nearCam and not nearHRP then return end

    -- Endpoint: hit position or max range
    local endPos
    if result and result.Position then
        endPos = result.Position
    else
        local cap = math.min(direction.Magnitude, TracerCFG.MaxLength)
        endPos = origin + direction.Unit * cap
    end

    spawnTracer(origin, endPos)
end

