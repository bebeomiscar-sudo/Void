-- SILENT AIM
-- ═══════════════════════════════════════════
local saFovCircle = Drawing.new("Circle")
saFovCircle.NumSides     = 64
saFovCircle.Visible      = false
saFovCircle.Color        = Color3.fromRGB(0, 200, 255)
saFovCircle.Thickness    = 1.5
saFovCircle.Transparency = 0.7
saFovCircle.Filled       = false

local saHookApplied = false
local saTarget      = nil
local saTargetChar  = nil
local saTargetConn  = nil

local saRayParams = RaycastParams.new()
saRayParams.FilterType = Enum.RaycastFilterType.Exclude

local function getEffectiveSAFOV()
    if SACFG.IgnoreFOV then return math.huge end
    local f = SACFG.FOVSize
    if SACFG.DynamicFOV then f = f * (camera.FieldOfView / 70) end
    return f
end

local function saIsValid(plr, camPos, center)
    local ch = plr.Character
    if not ch then return false end
    local hum = ch:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    local myEnv    = LP:GetAttribute("EnvironmentID")
    local theirEnv = plr:GetAttribute("EnvironmentID")
    if myEnv ~= nil and theirEnv ~= nil and myEnv ~= theirEnv then return false end
    if SACFG.TeamCheck and isSameTeam(plr) then return false end
    local tp = getBestPart(ch, SACFG.TargetParts)
    if not tp then return false end
    if not SACFG.IgnoreFOV then
        local sp, on = camera:WorldToViewportPoint(tp.Position)
        if not on then return false end
        if (Vector2.new(sp.X, sp.Y) - center).Magnitude > getEffectiveSAFOV() then return false end
    end
    if SACFG.VisCheck then
        saRayParams.FilterDescendantsInstances = {LP.Character, ch}
        local dir = tp.Position - camPos
        local hit = Workspace:Raycast(camPos, dir, saRayParams)
        if hit and not hit.Instance:IsDescendantOf(ch) then return false end
    end
    return true
end

local function saUpdateTarget()
    if not SACFG.On then saTarget = nil; saTargetChar = nil; return end
    local camPos = camera.CFrame.Position
    local center = camera.ViewportSize / 2
    local best, bd, bestChar = nil, math.huge, nil
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LP then continue end
        if not saIsValid(plr, camPos, center) then continue end
        local ch = plr.Character
        local tp = getBestPart(ch, SACFG.TargetParts)
        if not tp then continue end
        local sp, on = camera:WorldToViewportPoint(tp.Position)
        if not on then continue end
        local d = (Vector2.new(sp.X, sp.Y) - center).Magnitude
        if SACFG.Targeting == "Closest" and d < bd then
            bd = d; best = tp; bestChar = ch
        elseif SACFG.Targeting == "Furthest" and d > bd then
            bd = d; best = tp; bestChar = ch
        elseif SACFG.Targeting == "Random" then
            if not best or math.random() < 0.3 then best = tp; bestChar = ch end
        end
    end
    saTarget     = best
    saTargetChar = bestChar
end

local function applySARayHook()
    if saHookApplied then return end
    if not hookmetamethod then Library:Notify("SA: hookmetamethod not available", 4); return end
    local originalNamecall
    originalNamecall = hookmetamethod(game, "__namecall", newcclosure(function(self, ...)
        local method = getnamecallmethod()
        if method == "Raycast" and (self == Workspace or self == ws) then
            if SACFG.On and saTarget and saTargetChar then
                if math.random(1, 100) <= SACFG.HitChance then
                    if not checkcaller() then
                        local args   = {...}
                        local origin = args[1]
                        local dir    = args[2]
                        if origin and dir and typeof(origin) == "Vector3" and typeof(dir) == "Vector3" then
                            if dir.Magnitude > 50 then
                                local camPos      = camera.CFrame.Position
                                local distFromCam = (origin - camPos).Magnitude
                                local distFromHRP = math.huge
                                pcall(function()
                                    if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
                                        distFromHRP = (origin - LP.Character.HumanoidRootPart.Position).Magnitude
                                    end
                                end)
                                if distFromCam < 20 or distFromHRP < 10 then
                                    local newDir = (saTarget.Position - origin).Unit * dir.Magnitude
                                    return originalNamecall(self, origin, newDir, args[3])
                                end
                            end
                        end
                    end
                end
            end
        end
        return originalNamecall(self, ...)
    end))
    saHookApplied = true
end

local function startSA()
    applySARayHook()
    if saTargetConn then saTargetConn:Disconnect() end
    saTargetConn = RunService.Heartbeat:Connect(function() saUpdateTarget() end)
    saFovCircle.Visible = SACFG.DrawFOV
end

local function stopSA()
    SACFG.On = false; saTarget = nil; saTargetChar = nil
    if saTargetConn then saTargetConn:Disconnect(); saTargetConn = nil end
    saFovCircle.Visible = false
end

