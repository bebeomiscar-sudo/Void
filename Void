-- God Mode (Desync)
local desyncEnabled = false
local desyncClone = nil
local desyncBP = nil
local DESYNC_DEPTH = 1

MainSection:NewToggle({
    Title = "God Mode (Desync)",
    Description = "Become invincible to tsunami",
    Default = false,
    Callback = function(state)
        desyncEnabled = state
        if state then
            local char = LocalPlayer.Character
            if not char then return end
            
            char.Archivable = true
            local success, clone = pcall(function() return char:Clone() end)
            char.Archivable = false
            
            if not (success and clone) then
                Notification.new({Title = "Error", Description = "Failed to enable God Mode", Duration = 3, Icon = "alert-circle"})
                return
            end
            
            desyncClone = clone
            for _, obj in pairs(clone:GetDescendants()) do
                if obj:IsA("LocalScript") or obj:IsA("Script") then obj:Destroy() end
                if obj:IsA("BasePart") then
                    obj.Anchored = true
                    obj.CanCollide = false
                    obj.Transparency = 0
                end
            end
            
            local cloneHRP = clone:FindFirstChild("HumanoidRootPart")
            local cloneHum = clone:FindFirstChildOfClass("Humanoid")
            if not (cloneHRP and cloneHum) then
                clone:Destroy()
                desyncClone = nil
                return
            end
            
            cloneHRP.CFrame = char.HumanoidRootPart.CFrame
            clone.Parent = Workspace
            
            local bp = Instance.new("BodyPosition")
            bp.Position = char.HumanoidRootPart.Position
            bp.MaxForce = Vector3.new(0, math.huge, 0)
            bp.P = 1e5
            bp.D = 1e3
            bp.Parent = char.HumanoidRootPart
            desyncBP = bp
            
            -- Move real character underground
            local hrp = char.HumanoidRootPart
            hrp.CFrame = CFrame.new(hrp.Position.X, hrp.Position.Y - DESYNC_DEPTH, hrp.Position.Z) * (hrp.CFrame - hrp.CFrame.Position)
            
            -- Health protection loop
            RunService.Heartbeat:Connect(function()
                if not desyncEnabled then return end
                local c = LocalPlayer.Character
                if c then
                    local h = c:FindFirstChildOfClass("Humanoid")
                    if h then h.Health = h.MaxHealth end
                end
                
                if desyncClone and desyncClone.Parent then
                    local realHRP = c and c:FindFirstChild("HumanoidRootPart")
                    if realHRP then
                        bp.Position = realHRP.Position
                        local cloneHRP = desyncClone:FindFirstChild("HumanoidRootPart")
                        if cloneHRP then
                            cloneHRP.CFrame = CFrame.new(realHRP.Position.X, realHRP.Position.Y + DESYNC_DEPTH, realHRP.Position.Z)
                                * (realHRP.CFrame - realHRP.CFrame.Position)
                        end
                    end
                end
            end)
            
            Notification.new({Title = "God Mode", Description = "Enabled! You are now invincible.", Duration = 3, Icon = "shield"})
        else
            -- Cleanup
            if desyncBP and desyncBP.Parent then desyncBP:Destroy() end
            desyncBP = nil
            
            local char = LocalPlayer.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                if hrp then
                    hrp.CFrame = CFrame.new(hrp.Position.X, hrp.Position.Y + DESYNC_DEPTH, hrp.Position.Z)
                        * (hrp.CFrame - hrp.CFrame.Position)
                end
            end
            
            if desyncClone and desyncClone.Parent then
                desyncClone:Destroy()
                desyncClone = nil
            end
            
            Notification.new({Title = "God Mode", Description = "Disabled", Duration = 2, Icon = "shield-off"})
        end
    end
})

