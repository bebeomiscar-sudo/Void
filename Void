-- TRIGGERBOT
-- ═══════════════════════════════════════════
local triggerConn     = nil
local triggerLastSeen = 0
local triggerLastFire = 0

local triggerRayParams = RaycastParams.new()
triggerRayParams.FilterType  = Enum.RaycastFilterType.Exclude
triggerRayParams.IgnoreWater = true

local function getTriggerDelay()
    if TriggerCFG.RandomDelay then
        local lo = math.min(TriggerCFG.MinDelay, TriggerCFG.MaxDelay)
        local hi = math.max(TriggerCFG.MinDelay, TriggerCFG.MaxDelay)
        return math.random(lo, hi)
    end
    return TriggerCFG.Delay
end

local function triggerTargetValid(plr)
    if not plr or plr == LP then return false end
    local ch = plr.Character
    if not ch then return false end
    local hum = ch:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if TriggerCFG.TeamCheck and isSameTeam(plr) then return false end
    return true
end

local function triggerSendShot(item, hitPart)
    if not item or not hitPart then return end
    if not util_mod or not enums_mod or not useItemRemote then return end
    local objectID = nil
    pcall(function() objectID = item:Get("ObjectID") end)
    if not objectID then return end
    local camCF  = camera.CFrame
    local aimCF  = CFrame.lookAt(camCF.Position, hitPart.Position)
    local shootData = {}
    pcall(function()
        shootData[utf8.char(1)] = {
            [utf8.char(0)] = util_mod:EncodeCFrame(aimCF),
            [utf8.char(1)] = util_mod:EncodeCFrame(hitPart.CFrame),
            [utf8.char(2)] = hitPart,
            [utf8.char(3)] = util_mod:EncodeCFrame(
                hitPart.CFrame:ToObjectSpace(CFrame.new(hitPart.Position))
            ),
        }
    end)
    pcall(function()
        useItemRemote:FireServer(objectID, enums_mod:ToEnum("StartShooting"), shootData, nil)
    end)
    task.delay(0.07, function()
        pcall(function()
            useItemRemote:FireServer(objectID, enums_mod:ToEnum("StopShooting"), {}, nil)
        end)
    end)
end

local function startTriggerbot()
    if triggerConn then triggerConn:Disconnect() end
    triggerLastSeen = 0; triggerLastFire = 0
    triggerConn = RunService.Heartbeat:Connect(function()
        if not TriggerCFG.On then return end
        local myChar = LP.Character
        if not myChar then return end
        local myHum = myChar:FindFirstChildOfClass("Humanoid")
        if not myHum or myHum.Health <= 0 then return end
        local item = nil
        pcall(function()
            if fighter_mod and fighter_mod.LocalFighter then
                item = fighter_mod.LocalFighter.EquippedItem
            end
        end)
        if not item then return end
        local ammo = nil
        pcall(function() ammo = item:Get("CurrentAmmo") end)
        if ammo ~= nil and ammo <= 0 then return end
        local now    = tick()
        local center = getScreenCenter()
        local onTarget, foundPart = false, nil
        for _, plr in ipairs(Players:GetPlayers()) do
            if not triggerTargetValid(plr) then continue end
            local ch = plr.Character
            if not ch then continue end
            for _, partName in ipairs(ALL_PARTS) do
                local part = ch:FindFirstChild(partName)
                if not part then continue end
                local dist = (camera.CFrame.Position - part.Position).Magnitude
                if dist > TriggerCFG.MaxDist then continue end
                if TriggerCFG.VisCheck and not isVisible(camera.CFrame.Position, part) then continue end
                local sp, onScreen = camera:WorldToViewportPoint(part.Position)
                if not onScreen or sp.Z <= 0 then continue end
                local screenDist = (Vector2.new(sp.X, sp.Y) - center).Magnitude
                if screenDist <= TriggerCFG.FOVSize then
                    onTarget = true; foundPart = part; triggerLastSeen = now; break
                end
            end
            if onTarget then break end
        end
        local inGrace = (now - triggerLastSeen) * 1000 <= TriggerCFG.Grace
        if not onTarget and not inGrace then return end
        local delay = getTriggerDelay()
        if (now - triggerLastFire) * 1000 < delay then return end
        triggerLastFire = now
        if foundPart then triggerSendShot(item, foundPart) end
    end)
end

local function stopTriggerbot()
    TriggerCFG.On = false
    if triggerConn then triggerConn:Disconnect(); triggerConn = nil end
end

-- ═══════════════════════════════════════════
-- RAGEBOT — Fixed + Teleport Mode
--
-- Normal mode: shoots from current position
-- Teleport mode:
--   1. Save current CFrame
--   2. Teleport HRP directly behind/on target
--   3. Wait TeleportDelay ms
--   4. Fire shoot remote from that position
--   5. Teleport back to saved CFrame
--      (so in your POV you never moved)
-- ═══════════════════════════════════════════
local rageConn     = nil
local rageReloadCD = 0
local rageTeleporting = false  -- prevent overlapping teleports

local rageRayParams = RaycastParams.new()
rageRayParams.FilterType = Enum.RaycastFilterType.Exclude

local function rageIsValid(p)
    if p == LP then return false end
    if RageCFG.TeamCheck and isSameTeam(p) then return false end
    local ch  = p.Character
    if not ch then return false end
    local hum = ch:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    return true
end

local function rageGetClosest()
    local myHRP = character and character:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil, nil, nil end
    local best, bChar, bPart, bd = nil, nil, nil, RageCFG.MaxDist
    for _, p in ipairs(Players:GetPlayers()) do
        if not rageIsValid(p) then continue end
        local ch   = p.Character
        local part = getBestPart(ch, RageCFG.TargetPart)
        if not part then continue end
        if RageCFG.VisibleCheck then
            rageRayParams.FilterDescendantsInstances = {LP.Character, ch}
            local dir = part.Position - camera.CFrame.Position
            local hit = Workspace:Raycast(camera.CFrame.Position, dir, rageRayParams)
            if hit and not hit.Instance:IsDescendantOf(ch) then continue end
        end
        local dist = (myHRP.Position - part.Position).Magnitude
        if dist < bd then bd = dist; best = p; bChar = ch; bPart = part end
    end
    return best, bChar, bPart
end

--[[
    rageFireShot: Encodes and sends the shoot payload.
    shootOrigin is the position we're shooting FROM
    (either our real pos, or the teleported pos).
]]
local function rageFireShot(objectID, shootOriginPos, bPart)
    if not util_mod or not enums_mod or not useItemRemote then return end
    local aimCF = CFrame.lookAt(shootOriginPos, bPart.Position)
    local shootData = {}
    local ok = pcall(function()
        shootData[utf8.char(1)] = {
            [utf8.char(0)] = util_mod:EncodeCFrame(aimCF),
            [utf8.char(1)] = util_mod:EncodeCFrame(bPart.CFrame),
            [utf8.char(2)] = bPart,
            [utf8.char(3)] = util_mod:EncodeCFrame(
                bPart.CFrame:ToObjectSpace(CFrame.new(bPart.Position))
            ),
        }
    end)
    if not ok then return end
    pcall(function()
        useItemRemote:FireServer(objectID, enums_mod:ToEnum("StartShooting"), shootData, nil)
    end)
    task.delay(0.07, function()
        pcall(function()
            useItemRemote:FireServer(objectID, enums_mod:ToEnum("StopShooting"), {}, nil)
        end)
    end)
end

local function startRagebot()
    if rageConn then rageConn:Disconnect() end
    rageConn = RunService.Heartbeat:Connect(function(dt)
        if not RageCFG.On then return end
        if not LP.Character then return end
        if not util_mod or not enums_mod then return end
        if not fighter_mod or not useItemRemote then return end
        if rageTeleporting then return end

        local localFighter = nil
        pcall(function() localFighter = fighter_mod.LocalFighter end)
        if not localFighter then return end

        local item = localFighter.EquippedItem
        if not item then return end

        local objectID = nil
        pcall(function() objectID = item:Get("ObjectID") end)
        if not objectID then return end

        -- Auto-reload
        rageReloadCD = rageReloadCD - dt
        local ammo = nil
        pcall(function() ammo = item:Get("CurrentAmmo") end)
        if ammo ~= nil and ammo <= 0 and rageReloadCD <= 0 then
            pcall(function()
                useItemRemote:FireServer(objectID, enums_mod:ToEnum("Reload"), {}, nil)
            end)
            rageReloadCD = 2.0; return
        end

        local _, bChar, bPart = rageGetClosest()
        if not bChar or not bPart then return end

        local myHRP = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if not myHRP then return end

        if RageCFG.TeleportMode then
            -- ── TELEPORT MODE ──
            -- Prevent overlapping teleport sequences
            rageTeleporting = true

            -- 1. Save current CFrame so we can return
            local savedCF = myHRP.CFrame

            -- 2. Compute position directly behind the target
            --    relative to target's look direction
            local targetHRP = bChar:FindFirstChild("HumanoidRootPart")
            local teleportPos
            if targetHRP then
                -- Behind target = target pos - target's LookVector * dist
                local behindDir = targetHRP.CFrame.LookVector
                teleportPos = targetHRP.Position
                    - behindDir * RageCFG.TeleportDist
                    + Vector3.new(0, 0, 0)
            else
                -- Fallback: offset from target part
                teleportPos = bPart.Position - Vector3.new(0, 0, RageCFG.TeleportDist)
            end

            -- 3. Teleport there — client side only
            pcall(function()
                LP.Character:SetPrimaryPartCFrame(
                    CFrame.new(teleportPos) * CFrame.Angles(0, math.atan2(
                        -(bPart.Position.X - teleportPos.X),
                        -(bPart.Position.Z - teleportPos.Z)
                    ), 0)
                )
            end)

            -- 4. Wait TeleportDelay then fire from teleported position
            task.delay(RageCFG.TeleportDelay / 1000, function()
                rageFireShot(objectID, teleportPos, bPart)

                -- 5. Return to original CFrame
                task.delay(0.1, function()
                    if RageCFG.ReturnAfter and LP.Character then
                        pcall(function()
                            LP.Character:SetPrimaryPartCFrame(savedCF)
                        end)
                    end
                    rageTeleporting = false
                end)
            end)
        else
            -- ── NORMAL MODE ──
            -- Shoot from actual camera position, no teleport
            rageFireShot(objectID, camera.CFrame.Position, bPart)
        end
    end)
end

local function stopRagebot()
    RageCFG.On = false
    rageTeleporting = false
    if rageConn then rageConn:Disconnect(); rageConn = nil end
end

