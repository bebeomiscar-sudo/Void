-- ── helpers ───────────────────────────────────────────────────────────────────
local function sameteam(p)
    local ok = false
    pcall(function()
        local a = lp:GetAttribute("TeamID")
        local b = p:GetAttribute("TeamID")
        if a ~= nil and b ~= nil then ok = (a == b) end
    end)
    return ok
end

local function isalive(p)
    if p == lp then return false end
    local c = p.Character
    if not c then return false end
    local h = c:FindFirstChildOfClass("Humanoid")
    return h and h.Health > 0
end

local function gethrp(char)
    return char and char:FindFirstChild("HumanoidRootPart")
end

-- fire a shot at bp using the currently equipped item
local function fireshot(bp, origin)
    if not mUtil or not mEnum or not rUseItem then return end
    local lf = nil
    pcall(function() lf = mFig and mFig.LocalFighter end)
    if not lf then return end
    local item = lf.EquippedItem
    if not item then return end
    local oid = nil
    pcall(function() oid = item:Get("ObjectID") end)
    if not oid then return end
    local org   = origin or (ch and gethrp(ch) and gethrp(ch).Position + Vector3.new(0,1.5,0)) or Vector3.zero
    local aimCF = CFrame.lookAt(org, bp.Position)
    local sd    = {}
    pcall(function()
        sd[utf8.char(1)] = {
            [utf8.char(0)] = mUtil:EncodeCFrame(aimCF),
            [utf8.char(1)] = mUtil:EncodeCFrame(bp.CFrame),
            [utf8.char(2)] = bp,
            [utf8.char(3)] = mUtil:EncodeCFrame(bp.CFrame:ToObjectSpace(CFrame.new(bp.Position))),
        }
    end)
    pcall(function() rUseItem:FireServer(oid, mEnum:ToEnum("StartShooting"), sd, nil) end)
    task.delay(0.07, function()
        pcall(function() rUseItem:FireServer(oid, mEnum:ToEnum("StopShooting"), {}, nil) end)
    end)
end

-- find closest enemy, optionally skip team
local function closestEnemy(teamcheck)
    local myhrp = ch and gethrp(ch)
    if not myhrp then return nil, nil end
    local best, bc, bd = nil, nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if not isalive(p) then continue end
        if teamcheck and sameteam(p) then continue end
        local eh = gethrp(p.Character)
        if not eh then continue end
        local d = (myhrp.Position - eh.Position).Magnitude
        if d < bd then bd = d; best = p; bc = p.Character end
    end
    return best, bc
end

-- priority sort
local function sortedEnemies(mode, teamcheck)
    local myhrp = ch and gethrp(ch)
    if not myhrp then return {} end
    local list = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if not isalive(p) then continue end
        if teamcheck and sameteam(p) then continue end
        local eh = gethrp(p.Character)
        if not eh then continue end
        local hm = p.Character:FindFirstChildOfClass("Humanoid")
        table.insert(list, {
            player = p,
            char   = p.Character,
            hrp    = eh,
            dist   = (myhrp.Position - eh.Position).Magnitude,
            hp     = hm and hm.Health or 0,
        })
    end
    if     mode == "Closest" then table.sort(list, function(a,b) return a.dist < b.dist end)
    elseif mode == "LowHP"   then table.sort(list, function(a,b) return a.hp   < b.hp   end)
    elseif mode == "HighHP"  then table.sort(list, function(a,b) return a.hp   > b.hp   end)
    elseif mode == "Random"  then
        for i = #list, 2, -1 do
            local j = math.random(i)
            list[i], list[j] = list[j], list[i]
        end
    end
    return list
end

-- ═══════════════════════════════════════════════════════════════════════════════
--  FEATURE 1 — TELEPORT ATTACK
--  Save pos → tp onto enemy → shoot → return
--  Works without ragebot. Keybind or auto loop.
-- ═══════════════════════════════════════════════════════════════════════════════
local TP = {
    enabled    = false,
    targetMode = "Head",      -- Head / Legs / HRP
    priority   = "Closest",   -- Closest / LowHP / HighHP / Random
    teamcheck  = true,
    autoLoop   = false,        -- continuously tp + shoot in loop
    loopDelay  = 0.15,         -- seconds between each loop cycle
    shots      = 1,            -- shots to fire each visit
    running    = false,
}

local function tpAttack()
    if TP.running then return end
    local myhrp = ch and gethrp(ch)
    if not myhrp then return end

    local enemies = sortedEnemies(TP.priority, TP.teamcheck)
    if #enemies == 0 then return end
    local target = enemies[1]
    local tc     = target.char

    local savedCF = myhrp.CFrame

    -- pick landing spot
    local landPos
    if TP.targetMode == "Head" then
        local head = tc:FindFirstChild("Head")
        landPos = (head and head.Position or target.hrp.Position) + Vector3.new(0, 3.2, 0)
    elseif TP.targetMode == "Legs" then
        landPos = target.hrp.Position - Vector3.new(0, 2.8, 0)
    else
        landPos = target.hrp.Position + Vector3.new(0, 1, 0)
    end

    TP.running = true

    pcall(function() myhrp.CFrame = CFrame.new(landPos) end)
    task.wait(0.04)

    -- fire N shots
    local bp = tc:FindFirstChild("HumanoidRootPart") or tc:FindFirstChild("UpperTorso") or tc:FindFirstChild("Head")
    if bp then
        for i = 1, math.max(TP.shots, 1) do
            if i > 1 then task.wait(0.04) end
            fireshot(bp, myhrp.Position)
        end
    end

    task.wait(0.03)
    pcall(function() myhrp.CFrame = savedCF end)
    TP.running = false
end

local tpLoopConn = nil
local function startTPLoop()
    if tpLoopConn then tpLoopConn:Disconnect() end
    tpLoopConn = task.spawn(function()
        while TP.enabled and TP.autoLoop do
            if not TP.running then tpAttack() end
            task.wait(math.max(TP.loopDelay, 0.05))
        end
    end)
end
local function stopTPLoop()
    if tpLoopConn then
        pcall(function() tpLoopConn = nil end)
    end
end

-- ═══════════════════════════════════════════════════════════════════════════════
--  FEATURE 2 — ANTI-AIM
--  Heartbeat desync, RenderStepped restore (your view never breaks)
--  Pitch: Off / Up / Zero / Down / Glitch / Random
--  Yaw Base: Local / AtTarget
--  Yaw Mode: Off / Forward / Backward / Spin / GlitchSpin / StutterSpin
--  Yaw Angle: -180 to 180
--  Underground toggle
-- ═══════════════════════════════════════════════════════════════════════════════
local AA = {
    enabled     = false,
    pitch       = "Off",
    yawBase     = "Local",
    yaw         = "Off",
    yawAngle    = 0,
    underground = false,
}

local aaSavedCF = nil
local aaSavedLV = nil
local aaSavedAV = nil
local aaSpinA   = 0
local aaStutter = false
local aaHB      = nil
local aaRS      = nil

local function betterRandom(mi, ma, dmi, dma)
    local v = math.random(mi, ma)
    local guard = 0
    repeat
        v = math.random(mi, ma)
        guard = guard + 1
    until (v < dmi or v > dma) or guard > 30
    return v
end

local function buildAAFrame(dt)
    local myhrp = ch and ch:FindFirstChild("HumanoidRootPart")
    if not myhrp then return nil end
    local base = aaSavedCF or myhrp.CFrame
    local pos  = base.Position
    if AA.underground then pos = pos - Vector3.new(0, 5, 0) end

    local pitch = 0
    if     AA.pitch == "Up"     then pitch = math.rad(-89)
    elseif AA.pitch == "Zero"   then pitch = 0
    elseif AA.pitch == "Down"   then pitch = math.rad(89)
    elseif AA.pitch == "Glitch" then pitch = math.rad(betterRandom(-89, 89, -5, 5))
    elseif AA.pitch == "Random" then pitch = math.rad(math.random(-89, 89))
    end

    local _, ry, _ = base:ToEulerAnglesYXZ()
    local baseYaw  = ry
    if AA.yawBase == "AtTarget" then
        local _, tc = closestEnemy(true)
        if tc then
            local eh = gethrp(tc)
            if eh then
                local dir = (eh.Position - base.Position) * Vector3.new(1,0,1)
                if dir.Magnitude > 0.01 then
                    baseYaw = math.atan2(-dir.X, -dir.Z)
                end
            end
        end
    end

    local yoff = math.rad(AA.yawAngle)
    if     AA.yaw == "Forward"    then yoff = yoff + 0
    elseif AA.yaw == "Backward"   then yoff = yoff + math.pi
    elseif AA.yaw == "Spin"       then aaSpinA = aaSpinA + dt * math.rad(720); yoff = yoff + aaSpinA
    elseif AA.yaw == "GlitchSpin" then
        aaSpinA = aaSpinA + dt * math.rad(1440)
        yoff = yoff + aaSpinA + math.rad(betterRandom(-180, 180, -15, 15))
    elseif AA.yaw == "StutterSpin" then
        aaStutter = not aaStutter
        aaSpinA = aaStutter and (aaSpinA + dt * math.rad(720)) or (aaSpinA - dt * math.rad(360))
        yoff = yoff + aaSpinA
    end

    return CFrame.new(pos) * CFrame.fromEulerAnglesYXZ(pitch, baseYaw + yoff, 0)
end

local function stopAA()
    AA.enabled = false
    if aaHB then aaHB:Disconnect(); aaHB = nil end
    pcall(function() RunService:UnbindFromRenderStep("aa_sync") end)
    aaSpinA = 0; aaStutter = false; aaSavedCF = nil
end

local function startAA()
    stopAA()
    AA.enabled = true
    aaSpinA    = 0

    aaHB = RunService.Heartbeat:Connect(function(dt)
        if not AA.enabled then stopAA(); return end
        local myhrp = ch and ch:FindFirstChild("HumanoidRootPart")
        if not myhrp then return end
        aaSavedCF = myhrp.CFrame
        aaSavedLV = myhrp.AssemblyLinearVelocity
        aaSavedAV = myhrp.AssemblyAngularVelocity

        local desync = buildAAFrame(dt)
        if not desync then return end

        if AA.pitch == "Glitch" or AA.yaw == "GlitchSpin" then
            pcall(function()
                myhrp.CFrame = CFrame.new(
                    betterRandom(-2147483646, 2147483646, -1147483646, 1147483646),
                    betterRandom(-2147483646, 2147483646, -1147483646, 1147483646),
                    betterRandom(-2147483646, 2147483646, -1147483646, 1147483646)
                ) * CFrame.Angles(math.pi, math.pi, math.pi)
                myhrp.AssemblyLinearVelocity = Vector3.new(
                    betterRandom(-1e6, 1e6, -1e4, 1e4),
                    betterRandom(-1e6, 1e6, -1e4, 1e4),
                    betterRandom(-1e6, 1e6, -1e4, 1e4)
                )
                myhrp.AssemblyAngularVelocity = Vector3.new(
                    betterRandom(-1e6, 1e6, -1e4, 1e4),
                    betterRandom(-1e6, 1e6, -1e4, 1e4),
                    betterRandom(-1e6, 1e6, -1e4, 1e4)
                )
            end)
        else
            pcall(function() myhrp.CFrame = desync end)
        end
    end)

    RunService:BindToRenderStep("aa_sync", Enum.RenderPriority.First.Value, function()
        if not AA.enabled then return end
        local myhrp = ch and ch:FindFirstChild("HumanoidRootPart")
        if not myhrp or not aaSavedCF then return end
        pcall(function()
            myhrp.CFrame                  = aaSavedCF
            myhrp.AssemblyLinearVelocity  = aaSavedLV or Vector3.zero
            myhrp.AssemblyAngularVelocity = aaSavedAV or Vector3.zero
        end)
    end)
end

