TabT:CreateColorPicker({Name="Custom Tracer Color",
    Color=Color3.fromRGB(0,255,200), Flag="TracerColor",
    Callback=function(v) cfg.tracerColor=v end})

TabT:CreateSlider({Name="Tracer Width", Range={1,20}, Increment=1,
