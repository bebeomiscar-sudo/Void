-- ─── FLICKBOT ──────────────────────────────────
local flickConn    = nil
local flickCooldown = false

local function doFlick(targetPos)
    if flickCooldown then return end
    flickCooldown = true

    local steps = math.floor(CFG.FLICK_SPEED * 10)
    local startCF = Camera.CFrame
    local endCF   = CFrame.lookAt(startCF.Position, targetPos)

    for i = 1, steps do
        RunService.Heartbeat:Wait()
        if not CFG.FLICK_ENABLED then break end
        local alpha = i / steps
        local smooth = alpha * CFG.FLICK_SMOOTH
        pcall(function()
            Camera.CFrame = startCF:Lerp(endCF, smooth)
        end)
    end

    task.wait(CFG.FLICK_DELAY)
    flickCooldown = false
end

local function startFlickbot()
    if flickConn then flickConn:Disconnect(); flickConn = nil end
    flickConn = RunService.Heartbeat:Connect(function()
        if not CFG.FLICK_ENABLED then
            flickConn:Disconnect(); flickConn = nil; return
        end
        if not UIS:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then return end
        if flickCooldown then return end

        local target, dist = getClosestPlayer(CFG.FLICK_FOV)
        if not target or not target.Character then return end

        local bone = getBone(target.Character, CFG.SILENT_AIM_BONE)
        if not bone then return end

        task.spawn(doFlick, bone.Position)
    end)
end

local function stopFlickbot()
    if flickConn then flickConn:Disconnect(); flickConn = nil end
end

-- ─── RAGEBOT ───────────────────────────────────
local ragebotConn = nil
local ragebotAngle = 0
local ragebotTimer = 0

local EVASION_MODES = {
    ProjectileBreaker = function(hrp, t, cfg)
        -- Rapidly move hitbox to break projectile tracking
        local offsets = {
            Vector3.new(cfg.RAGEBOT_DEPTH_FORWARD, 0, 0),
            Vector3.new(-cfg.RAGEBOT_DEPTH_FORWARD, 0, 0),
            Vector3.new(0, cfg.RAGEBOT_DEPTH_UP, 0),
            Vector3.new(0, -cfg.RAGEBOT_DEPTH_UP, 0),
        }
        local idx = math.floor(t * 20) % #offsets + 1
        pcall(function()
            hrp.CFrame = hrp.CFrame + offsets[idx]
        end)
    end,

    Jitter = function(hrp, t, cfg)
        -- Random micro jitter to confuse hitscans
        local jx = (math.random() - 0.5) * cfg.RAGEBOT_DEPTH_FORWARD * 2
        local jy = (math.random() - 0.5) * cfg.RAGEBOT_DEPTH_UP * 2
        pcall(function()
            hrp.CFrame = hrp.CFrame + Vector3.new(jx, jy, 0)
        end)
    end,

    Spin = function(hrp, t, cfg)
        -- Spin body rapidly
        ragebotAngle = ragebotAngle + 25
        pcall(function()
            hrp.CFrame = CFrame.new(hrp.Position) * CFrame.Angles(0, math.rad(ragebotAngle), 0)
        end)
    end,

    FallbackOnly = function(hrp, t, cfg)
        -- Use fallback radius randomization
        local angle = t * 10
        local r = cfg.RAGEBOT_FALLBACK_RADIUS * cfg.RAGEBOT_FALLBACK_RANDOM
        local offset = Vector3.new(
            math.cos(angle) * r,
            cfg.RAGEBOT_DOWN_OFFSET,
            math.sin(angle) * r
        )
        if cfg.RAGEBOT_FALLBACK_ORIGIN then
            pcall(function()
                hrp.CFrame = CFrame.new(hrp.Position + offset)
            end)
        end
    end,

    Desync = function(hrp, t, cfg)
        -- Desync hitbox from visual
        local savedPos = hrp.Position
        pcall(function()
            hrp.CFrame = CFrame.new(
                savedPos.X + math.sin(t*50)*cfg.RAGEBOT_DEPTH_FORWARD,
                savedPos.Y + math.cos(t*50)*cfg.RAGEBOT_DEPTH_UP,
                savedPos.Z
            )
        end)
    end,

    AntiAim = function(hrp, t, cfg)
        -- Flip aim direction to confuse aimbot
        ragebotAngle = ragebotAngle + 180
        pcall(function()
            hrp.CFrame = CFrame.new(hrp.Position) *
                CFrame.Angles(
                    math.rad(math.sin(t*10)*30),
                    math.rad(ragebotAngle),
                    math.rad(math.cos(t*10)*30)
                )
        end)
    end,
}

local function startRagebot()
    if ragebotConn then ragebotConn:Disconnect(); ragebotConn = nil end
    ragebotConn = RunService.Heartbeat:Connect(function(dt)
        if not CFG.RAGEBOT_ENABLED then
            ragebotConn:Disconnect(); ragebotConn = nil; return
        end

        local hrp = getHRP()
        if not hrp then return end

        ragebotTimer = ragebotTimer + dt

        -- Apply reposition interval
        if ragebotTimer < CFG.RAGEBOT_REPOSITION_INT then return end
        ragebotTimer = 0

        local mode = EVASION_MODES[CFG.RAGEBOT_EVASION_MODE]
        if mode then
            pcall(mode, hrp, tick(), CFG)
        end
    end)
end

local function stopRagebot()
    if ragebotConn then ragebotConn:Disconnect(); ragebotConn = nil end
end

