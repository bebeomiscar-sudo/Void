-- ESP
-- ═══════════════════════════════════════════
local espEnabled = false
local espBoxes   = {}

local function clearESP()
    for _, h in pairs(espBoxes) do if h and h.Parent then h:Destroy() end end
    espBoxes = {}
end

local function updateESP()
    if not espEnabled then clearESP(); return end
    for _, p in ipairs(Players:GetPlayers()) do
        if p == LP then continue end
        local ch  = p.Character
        local hrp = ch and ch:FindFirstChild("HumanoidRootPart")
        local hum = ch and ch:FindFirstChildOfClass("Humanoid")
        if not ch or not hrp or not hum or hum.Health <= 0 then
            if espBoxes[p] then espBoxes[p]:Destroy(); espBoxes[p] = nil end
            continue
        end
        if not espBoxes[p] then
            local h = Instance.new("SelectionBox")
            h.Color3              = Color3.fromRGB(255, 50, 50)
            h.LineThickness       = 0.05
            h.SurfaceTransparency = 1
            h.Adornee             = ch
            h.Parent              = Workspace
            espBoxes[p] = h
        end
    end
    for p, h in pairs(espBoxes) do
        if not p.Character or not p.Character.Parent then
            h:Destroy(); espBoxes[p] = nil
        end
    end
end

