Connections.VoidHeartbeat = RunService.Heartbeat:Connect(function()
    -- Only run base void if ragebot is OFF
    -- Ragebot manages its own void cycle
    if not Config.Movement.EnableVoid then return end
    if Config.Ragebot.Enabled then return end

    pcall(function()
        hrp      = LocalPlayer.Character.HumanoidRootPart
        clientC  = hrp.CFrame
        clientV  = hrp.AssemblyLinearVelocity
        clientVA = hrp.AssemblyAngularVelocity

        if Config.Movement.EnableVoidSpam then
            local delay = Config.Movement.VoidDelay
            hrp.CFrame = CFrame.new(
                betterRandom(-2147483646, 2147483646, -1147483646, 1147483646),
                delay,
                betterRandom(-2147483646, 2147483646, -1147483646, 1147483646)
            )
            hrp.AssemblyLinearVelocity = Vector3.new(
                betterRandom(-999999, 999999, -500000, 500000),
                0,
                betterRandom(-999999, 999999, -500000, 500000)
            )
        end
    end)
end)

Connections.VoidRender = RunService:BindToRenderStep(
    "VoidRestore",
    Enum.RenderPriority.First.Value,
    function()
        if hrp and (Config.Movement.EnableVoid or Config.Ragebot.Enabled) then
            pcall(function()
                hrp.CFrame                  = clientC
                hrp.AssemblyLinearVelocity  = clientV
                hrp.AssemblyAngularVelocity = clientVA
            end)
        end
    end
)

--[[
    ═══════════════════════════════
    RAGEBOT — Hide/Attack Cycle
    
    HOW IT WORKS:
    1. HIDE phase  — teleport to void so enemy
       cant hit you. Duration = HideTime
    2. ATTACK phase — teleport back to real pos
       so YOUR shots register. Fire ShootAttempts
       times then go back to hide.
       Duration = AttackTime
    
    TO BEAT UE USERS:
    - Lower HideTime  = you spend less time safe
      but enemy has less window to hit you
    - Lower AttackTime = tighter window, harder
      for their script to react
    - Higher ShootAttempts = more shots per window
    ═══════════════════════════════
]]

local function stopRagebotThread()
    ragebotRunning = false
    ragebotThread  = nil
end

local function startRagebotThread()
    if ragebotRunning then return end
    ragebotRunning = true

    ragebotThread = task.spawn(function()
        while ragebotRunning and Config.Ragebot.Enabled do
            -- Grab character each cycle in case of respawn
            local char = LocalPlayer.Character
            if not char then task.wait(0.1); continue end

            local root = char:FindFirstChild("HumanoidRootPart")
            if not root then task.wait(0.1); continue end

            -- Save real position at start of cycle
            local realCFrame = root.CFrame
            local realLinVel = root.AssemblyLinearVelocity
            local realAngVel = root.AssemblyAngularVelocity

            -- ── HIDE PHASE ──
            -- Go to void — enemy bullets can't hit us
            pcall(function()
                hrp      = root
                clientC  = realCFrame
                clientV  = realLinVel
                clientVA = realAngVel

                root.CFrame = CFrame.new(
                    betterRandom(-2147483646, 2147483646, -1147483646, 1147483646),
                    Config.Movement.VoidDelay,
                    betterRandom(-2147483646, 2147483646, -1147483646, 1147483646)
                )
                root.AssemblyLinearVelocity = Vector3.new(
                    betterRandom(-999999, 999999, -500000, 500000),
                    0,
                    betterRandom(-999999, 999999, -500000, 500000)
                )
            end)

            task.wait(Config.Ragebot.HideTime)
            if not ragebotRunning or not Config.Ragebot.Enabled then break end

            -- ── ATTACK PHASE ──
            -- Come back to real pos so our shots register
            pcall(function()
                root.CFrame                  = realCFrame
                root.AssemblyLinearVelocity  = realLinVel
                root.AssemblyAngularVelocity = realAngVel
                clientC  = realCFrame
                clientV  = realLinVel
                clientVA = realAngVel
            end)

            -- Multiple shoot attempts within attack window
            local attemptDelay = Config.Ragebot.AttackTime / math.max(Config.Ragebot.ShootAttempts, 1)
            for i = 1, Config.Ragebot.ShootAttempts do
                if not ragebotRunning or not Config.Ragebot.Enabled then break end
                -- Shots fire from real position — server validates hit
                task.wait(attemptDelay)
            end

            if not ragebotRunning or not Config.Ragebot.Enabled then break end
        end

        ragebotRunning = false
    end)
end

--[[
    ═══════════════════════════════
    ADVANCED ORBIT
    ═══════════════════════════════
]]

Connections.AdvancedOrbit = RunService.Heartbeat:Connect(function()
    if not (Config.AdvancedOrbit.Wallbang or Config.AdvancedOrbit.TeleportAura) then return end

    pcall(function()
        local enemy, distance = GetClosestEnemy()
        if not enemy then return end

        local enemyRoot  = enemy.Character.HumanoidRootPart
        local playerRoot = LocalPlayer.Character.HumanoidRootPart

        if distance <= Config.AdvancedOrbit.Distance then
            if Config.AdvancedOrbit.Wallbang then
                if not IsWallBetween(playerRoot.Position, enemyRoot.Position) then
                    return
                end
            end

            if Config.AdvancedOrbit.TeleportAura then
                local t      = tick() * Config.AdvancedOrbit.Speed
                local radius = Config.AdvancedOrbit.Distance
                local offset = Vector3.new(
                    math.sin(t) * radius,
                    0,
                    math.cos(t) * radius
                )
                enemyRoot.CFrame = CFrame.new(playerRoot.Position + offset)
            end
        end
    end)
end)

