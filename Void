-- Lighting Intensity
local savedLighting       = nil
local lightIntensityOn    = false
local lightIntensityValue = 100

local function saveLighting()
    if savedLighting then return end
    savedLighting = {
        Brightness     = Lighting.Brightness,
        Ambient        = Lighting.Ambient,
        OutdoorAmbient = Lighting.OutdoorAmbient,
    }
end

local function applyLightingIntensity(v)
    saveLighting()
    local m = math.clamp(v / 100, 0.01, 5)
    Lighting.Brightness     = savedLighting.Brightness * m
    Lighting.Ambient        = Color3.new(
        math.clamp(savedLighting.Ambient.R * m, 0, 1),
        math.clamp(savedLighting.Ambient.G * m, 0, 1),
        math.clamp(savedLighting.Ambient.B * m, 0, 1)
    )
    Lighting.OutdoorAmbient = Color3.new(
        math.clamp(savedLighting.OutdoorAmbient.R * m, 0, 1),
        math.clamp(savedLighting.OutdoorAmbient.G * m, 0, 1),
        math.clamp(savedLighting.OutdoorAmbient.B * m, 0, 1)
    )
end

local function restoreLighting()
    if not savedLighting then return end
    Lighting.Brightness     = savedLighting.Brightness
    Lighting.Ambient        = savedLighting.Ambient
    Lighting.OutdoorAmbient = savedLighting.OutdoorAmbient
    savedLighting = nil
end

-- Snow (3D)
local snowParts = {}
local snowConn  = nil

local function randomSnowPos()
    local cp = camera and camera.CFrame.Position or Vector3.new(0, 50, 0)
    return Vector3.new(
        cp.X + math.random(-50, 50),
        cp.Y + math.random(5, 30),
        cp.Z + math.random(-50, 50)
    )
end

local function startSnow()
    if snowConn then return end
    for i = 1, 120 do
        local p = Instance.new("Part")
        p.Size         = Vector3.new(0.2, 0.2, 0.2)
        p.Shape        = Enum.PartType.Ball
        p.Anchored     = true
        p.CanCollide   = false
        p.CastShadow   = false
        p.Material     = Enum.Material.SmoothPlastic
        p.Color        = Color3.fromRGB(240, 240, 255)
        p.Transparency = 0.3
        p.Position     = randomSnowPos()
        p.Parent       = Workspace
        table.insert(snowParts, p)
    end
    snowConn = RunService.Heartbeat:Connect(function(dt)
        local cp = camera and camera.CFrame.Position or Vector3.new(0, 50, 0)
        for _, p in ipairs(snowParts) do
            if not p or not p.Parent then continue end
            p.Position = p.Position + Vector3.new(
                math.sin(tick() * 0.5 + p.Position.X) * 0.02,
                -0.15 * dt * 60,
                math.cos(tick() * 0.3 + p.Position.Z) * 0.02
            )
            if (p.Position - cp).Magnitude > 60 or p.Position.Y < cp.Y - 20 then
                p.Position = randomSnowPos()
            end
        end
    end)
end

local function stopSnow()
    if snowConn then snowConn:Disconnect(); snowConn = nil end
    for _, p in ipairs(snowParts) do pcall(function() p:Destroy() end) end
    snowParts = {}
end

